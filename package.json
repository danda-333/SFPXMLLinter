{
  "name": "sfp-xml-linter",
  "displayName": "SFP XML Linter",
  "description": "IntelliSense, diagnostics, references, and template tooling for SFP XML projects.",
  "publisher": "DanielSasek",
  "license": "MIT",
  "version": "0.1.1",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Linters"
  ],
  "keywords": [
    "xml",
    "linter",
    "intellisense",
    "workflow",
    "sfp"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/danda-333/SFPXMLLinter.git"
  },
  "activationEvents": [
    "onLanguage:xml",
    "onStartupFinished",
    "onCommand:sfpXmlLinter.buildXmlTemplates",
    "onCommand:sfpXmlLinter.buildXmlTemplatesAll",
    "onCommand:sfpXmlLinter.createDocumentGeneratorTemplate",
    "onCommand:sfpXmlLinter.createSnippetGeneratorTemplate",
    "onCommand:sfpXmlLinter.showBuildQueueLog",
    "onCommand:sfpXmlLinter.showIndexLog",
    "onCommand:sfpXmlLinter.showCompositionLog",
    "onCommand:sfpXmlLinter.generateFeatureManifestBootstrap",
    "onCommand:sfpXmlLinter.refreshCompositionView",
    "onCommand:sfpXmlLinter.compositionOpenSource",
    "onCommand:sfpXmlLinter.compositionOpenSourceBeside",
    "onCommand:sfpXmlLinter.compositionOpenSourceSidePreview",
    "onCommand:sfpXmlLinter.compositionShowUsages",
    "onCommand:sfpXmlLinter.rebuildIndex",
    "onCommand:sfpXmlLinter.revalidateWorkspace",
    "onCommand:sfpXmlLinter.revalidateProject",
    "onCommand:sfpXmlLinter.switchProjectScopeToActiveFile",
    "onCommand:sfpXmlLinter.workspaceDiagnosticsReport",
    "onCommand:sfpXmlLinter.formatDocumentTolerant",
    "onCommand:sfpXmlLinter.formatSelectionTolerant"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "semanticTokenTypes": [
      {
        "id": "sfpSqlPlaceholder",
        "description": "SFP SQL placeholder token inside XML SQL/Command blocks."
      },
      {
        "id": "sfpSqlString",
        "description": "SFP SQL string literal token inside XML SQL/Command blocks."
      }
    ],
    "grammars": [
      {
        "scopeName": "sfp.xml.core",
        "path": "./syntaxes/sfp-xml-core.tmLanguage.json",
        "injectTo": [
          "text.xml"
        ]
      },
      {
        "scopeName": "sfp.xml.embedded",
        "path": "./syntaxes/sfp-xml-embedded.tmLanguage.json",
        "embeddedLanguages": {
          "meta.embedded.block.sfp.sql.xml": "sql",
          "meta.embedded.block.sfp.command.xml": "sql",
          "meta.embedded.block.sfp.htmltemplate.xml": "html"
        },
        "injectTo": [
          "text.xml"
        ]
      },
      {
        "scopeName": "sfp.sql.placeholders",
        "path": "./syntaxes/sfp-sql-placeholders.tmLanguage.json",
        "injectTo": [
          "source.sql"
        ]
      }
    ],
    "commands": [
      {
        "command": "sfpXmlLinter.buildXmlTemplates",
        "title": "SFP XML Linter: Build XML Templates (Current / Selection)"
      },
      {
        "command": "sfpXmlLinter.buildXmlTemplatesAll",
        "title": "SFP XML Linter: Build XML Templates (All)"
      },
      {
        "command": "sfpXmlLinter.createDocumentGeneratorTemplate",
        "title": "SFP XML Linter: Create Generator Template (Document)"
      },
      {
        "command": "sfpXmlLinter.createSnippetGeneratorTemplate",
        "title": "SFP XML Linter: Create Generator Template (Snippet)"
      },
      {
        "command": "sfpXmlLinter.showBuildQueueLog",
        "title": "SFP XML Linter: Show Build Queue Log"
      },
      {
        "command": "sfpXmlLinter.showIndexLog",
        "title": "SFP XML Linter: Show Index Log"
      },
      {
        "command": "sfpXmlLinter.showCompositionLog",
        "title": "SFP XML Linter: Show Composition Log"
      },
      {
        "command": "sfpXmlLinter.generateFeatureManifestBootstrap",
        "title": "SFP XML Linter: Generate Feature Manifest Bootstrap"
      },
      {
        "command": "sfpXmlLinter.refreshCompositionView",
        "title": "SFP XML Linter: Refresh Composition View"
      },
      {
        "command": "sfpXmlLinter.compositionOpenSource",
        "title": "SFP XML Linter: Composition Open Source",
        "icon": "$(go-to-file)"
      },
      {
        "command": "sfpXmlLinter.compositionOpenSourceBeside",
        "title": "SFP XML Linter: Composition Open Source To Side",
        "icon": "$(split-horizontal)"
      },
      {
        "command": "sfpXmlLinter.compositionOpenSourceSidePreview",
        "title": "SFP XML Linter: Composition Open Source Side Preview",
        "icon": "$(open-preview)"
      },
      {
        "command": "sfpXmlLinter.compositionShowUsages",
        "title": "SFP XML Linter: Composition Show Usages",
        "icon": "$(references)"
      },
      {
        "command": "sfpXmlLinter.workspaceDiagnosticsReport",
        "title": "SFP XML Linter: Workspace Diagnostics Report"
      },
      {
        "command": "sfpXmlLinter.rebuildIndex",
        "title": "SFP XML Linter: Rebuild Full Index"
      },
      {
        "command": "sfpXmlLinter.revalidateWorkspace",
        "title": "SFP XML Linter: Revalidate Workspace (Full)"
      },
      {
        "command": "sfpXmlLinter.revalidateProject",
        "title": "SFP XML Linter: Revalidate Current Project"
      },
      {
        "command": "sfpXmlLinter.switchProjectScopeToActiveFile",
        "title": "SFP XML Linter: Switch Project Scope To Active File"
      },
      {
        "command": "sfpXmlLinter.formatDocumentTolerant",
        "title": "SFP XML Linter: Format Document (Tolerant)"
      },
      {
        "command": "sfpXmlLinter.formatSelectionTolerant",
        "title": "SFP XML Linter: Format Selection (Tolerant)"
      }
    ],
    "views": {
      "explorer": [
        {
          "id": "sfpXmlLinter.compositionView",
          "name": "SFP Composition"
        }
      ]
    },
    "menus": {
      "view/title": [
        {
          "command": "sfpXmlLinter.refreshCompositionView",
          "when": "view == sfpXmlLinter.compositionView",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "sfpXmlLinter.compositionOpenSource",
          "when": "view == sfpXmlLinter.compositionView && viewItem =~ /^composition(Feature|FeaturePart|Contribution|Using|Symbol)$/",
          "group": "inline@1"
        },
        {
          "command": "sfpXmlLinter.compositionOpenSourceSidePreview",
          "when": "view == sfpXmlLinter.compositionView && viewItem =~ /^composition(Feature|FeaturePart|Contribution|Using|Symbol)$/",
          "group": "inline@2"
        },
        {
          "command": "sfpXmlLinter.compositionShowUsages",
          "when": "view == sfpXmlLinter.compositionView && viewItem =~ /^composition(Feature|FeaturePart|Contribution|Using)$/",
          "group": "inline@3"
        }
      ]
    },
    "configuration": {
      "title": "SFP XML Linter",
      "properties": {
        "sfpXmlLinter.workspaceRoots": {
          "type": "array",
          "default": [
            "XML",
            "XML_Templates",
            "XML_Components",
            "XML_Primitives"
          ],
          "items": {
            "type": "string"
          },
          "description": "Folders to scan for XML symbols and validations (including template components/primitives)."
        },
        "sfpXmlLinter.resourcesRoots": {
          "type": "array",
          "default": [
            "Resources"
          ],
          "items": {
            "type": "string"
          },
          "description": "Reserved for future translations-related features."
        },
        "sfpXmlLinter.hoverDocsFiles": {
          "type": "array",
          "default": [
            "Docs/hover-docs.json",
            "Docs/hover-docs.team.json"
          ],
          "items": {
            "type": "string"
          },
          "description": "List of JSON files with concise hover documentation entries."
        },
        "sfpXmlLinter.rules": {
          "type": "object",
          "default": {
            "unknown-form-ident": "error",
            "unknown-form-control-ident": "error",
            "unknown-form-button-ident": "error",
            "unknown-workflow-button-share-code-ident": "error",
            "unknown-form-section-ident": "warning",
            "unknown-mapping-ident": "warning",
            "unknown-mapping-form-ident": "warning",
            "unknown-required-action-ident": "warning",
            "unknown-workflow-action-value-control-ident": "error",
            "unknown-workflow-show-hide-control-ident": "error",
            "unknown-html-template-control-ident": "error",
            "duplicate-control-ident": "warning",
            "duplicate-button-ident": "warning",
            "duplicate-section-ident": "warning",
            "unknown-using-feature": "error",
            "unknown-using-contribution": "warning",
            "contribution-mismatch": "warning",
            "unused-using": "information",
            "partial-using": "information",
            "unknown-primitive": "warning",
            "primitive-missing-slot": "warning",
            "primitive-missing-param": "warning",
            "primitive-cycle": "warning",
            "workflow-redundant-feature-using": "warning",
            "dataview-redundant-feature-using": "warning",
            "feature-inheritance-override": "information",
            "suppression-conflict": "warning",
            "suppression-noop": "information",
            "typo-maxlenght-attribute": "warning",
            "sql-convention-equals-spacing": "warning",
            "ident-convention-button-postfix": "warning",
            "ident-convention-group-button-postfix": "warning",
            "ident-convention-workflow-postfix": "warning",
            "ident-convention-view-postfix": "warning",
            "ident-convention-lookup-control": "warning",
            "unknown-feature-requirement": "warning",
            "missing-feature-dependency": "warning",
            "missing-feature-expectation": "warning",
            "missing-feature-expected-xpath": "warning",
            "duplicate-feature-provider": "warning",
            "ordering-conflict": "warning",
            "orphan-feature-part": "warning",
            "incomplete-feature": "warning",
            "unused-feature-contribution": "information",
            "partial-feature-contribution": "information"
          },
          "description": "Per-rule severity mapping. Allowed values: off, information, warning, error."
        },
        "sfpXmlLinter.incompleteMode": {
          "type": "boolean",
          "default": false,
          "description": "When enabled, suppresses diagnostics that require unknown FormIdent resolution (useful for incomplete projects with external forms/tables)."
        },
        "sfpXmlLinter.formatter.maxConsecutiveBlankLines": {
          "type": "number",
          "default": 2,
          "minimum": 0,
          "description": "Maximum number of consecutive blank lines preserved by the formatter."
        },
        "sfpXmlLinter.templateBuilder.autoBuildOnSave": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, saving XML_Templates/XML_Components/XML_Primitives files automatically triggers BuildXmlTemplates."
        },
        "sfpXmlLinter.templateBuilder.componentSaveBuildScope": {
          "type": "string",
          "enum": [
            "dependents",
            "full"
          ],
          "default": "dependents",
          "description": "On XML_Components/XML_Primitives save, build only dependent templates when possible (dependents) or rebuild all templates (full)."
        },
        "sfpXmlLinter.templateBuilder.mode": {
          "type": "string",
          "enum": [
            "fast",
            "debug",
            "release"
          ],
          "default": "debug",
          "description": "Template builder logging/detail mode. fast minimizes overhead, debug prints detailed composition diagnostics, release keeps only high-level output."
        },
        "sfpXmlLinter.templateBuilder.postBuildFormat": {
          "type": "boolean",
          "default": true,
          "description": "When enabled, final built XML is passed through internal tolerant formatter before write."
        },
        "sfpXmlLinter.templateBuilder.provenanceMode": {
          "type": "string",
          "enum": [
            "off",
            "fileComment"
          ],
          "default": "off",
          "description": "Adds optional provenance marker to final built XML output."
        },
        "sfpXmlLinter.templateBuilder.generators.enabled": {
          "type": "boolean",
          "default": true,
          "description": "Enable build-time XML generators pipeline (deterministic transform stage after rendering)."
        },
        "sfpXmlLinter.templateBuilder.generators.timeoutMs": {
          "type": "number",
          "default": 150,
          "minimum": 50,
          "description": "Soft timeout budget for template generators per file in milliseconds."
        },
        "sfpXmlLinter.templateBuilder.generators.enableUserScripts": {
          "type": "boolean",
          "default": true,
          "description": "Enable user-defined JS/TS generators loaded from workspace roots."
        },
        "sfpXmlLinter.templateBuilder.generators.userScriptsRoots": {
          "type": "array",
          "default": [
            "XML_Generators"
          ],
          "items": {
            "type": "string"
          },
          "description": "Workspace-relative folders scanned for user-defined template generators (*.js, *.cjs, *.mjs, *.ts)."
        },
        "sfpXmlLinter.composition.openMode": {
          "type": "string",
          "enum": [
            "peek",
            "side",
            "sidePreview",
            "newTab",
            "current"
          ],
          "default": "newTab",
          "description": "How Composition Open Source navigates: peek inline preview, open to side editor, open as new tab, or reuse current editor tab."
        }
      }
    },
    "configurationDefaults": {
      "[xml]": {
        "editor.defaultFormatter": "DanielSasek.sfp-xml-linter",
        "editor.quickSuggestions": {
          "other": "on",
          "comments": "off",
          "strings": "on"
        }
      },
      "editor.semanticTokenColorCustomizations": {
        "rules": {
          "sfpSqlPlaceholder": "#7FDBFF",
          "sfpSqlString": "#F44747"
        }
      },
      "editor.tokenColorCustomizations": {
        "textMateRules": [
          {
            "scope": "variable.parameter.sfp.sql.strong",
            "settings": {
              "foreground": "#FF9800"
            }
          },
          {
            "scope": "constant.other.sfp.sql-placeholder",
            "settings": {
              "foreground": "#7FDBFF"
            }
          },
          {
            "scope": "keyword.other.sfp.sql-update",
            "settings": {
              "foreground": "#C586C0"
            }
          }
        ]
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "test:formatter": "npm run compile && node out/tests/formatter/runFormatterFixtures.js && node out/tests/formatter/runSelectionFormatterTests.js",
    "test:linter": "npm run compile && node out/tests/linter/runLinterFixtures.js && node out/tests/linter/runIgnoreCodeActionProviderTests.js",
    "test:linter:perf": "npm run compile && node out/tests/linter/runLinterPerformance.js",
    "test:composition": "npm run compile && node out/tests/composition/runCompositionModelTests.js && node out/tests/composition/runCompositionWorkspaceTests.js && node out/tests/composition/runCompositionDiagnosticsTests.js && node out/tests/composition/runCompositionBootstrapTests.js && node out/tests/composition/runDocumentCompositionModelTests.js && node out/tests/composition/runCompositionOrderingFixtureTests.js && node out/tests/composition/runPrimitiveQuickFixCommandTests.js && node out/tests/composition/runTreeQuickFixPayloadTests.js && node out/tests/indexer/runWorkspaceIndexerUsageTests.js",
    "test:templates:core": "npm run compile && node out/tests/template/runBuildTemplateCoreTests.js && node out/tests/template/runTemplateGeneratorsTests.js",
    "test:templates:perf": "npm run compile && node out/tests/template/runTemplateGeneratorsPerformanceCheckpoint.js",
    "test:templates:service": "npm run compile && node out/tests/template/runBuildTemplateServiceTests.js",
    "test:templates": "npm run compile && node out/tests/template/runBuildTemplateCoreTests.js && node out/tests/template/runTemplateGeneratorsTests.js && node out/tests/template/runBuildTemplatePrimitiveTests.js && node out/tests/template/runBuildTemplateServiceTests.js && node out/tests/template/runBuildTemplateFixtures.js",
    "schemas:generate": "powershell -NoProfile -ExecutionPolicy Bypass -File Scripts/GenerateSchemaCatalog.ps1",
    "package:vsix": "npx @vscode/vsce package"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/vscode": "^1.90.0"
  },
  "dependencies": {
    "@xmldom/xmldom": "^0.8.11",
    "xpath": "^0.0.34",
    "typescript": "^5.5.4"
  }
}
