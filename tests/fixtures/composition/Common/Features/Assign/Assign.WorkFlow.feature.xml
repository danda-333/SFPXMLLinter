	</Contribution>

	<Contribution Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">

		<Action xsi:type="ActionTrigger" Ident="AssignedGroupID_Update_GroupFromCategory_Action" ActionStart="AfterSave">
			<DataSource>
				<SQL><![CDATA[

					DECLARE @PermissionIDs dbo.ListNVarchar100Type;
					INSERT INTO @PermissionIDs VALUES ('ITSMOperator');

					DECLARE @UpdateOutput TABLE (OldAssignedGroupID INT, NewAssignedGroupID INT)

					UPDATE itsReq
						SET AssignedGroupID = ISNULL(itsCat.DefaultAssignedGroupID, itsGagbttap.GroupID)
					OUTPUT DELETED.AssignedGroupID AS OldAssignedGroupID, INSERTED.AssignedGroupID AS NewAssignedGroupID
					INTO @UpdateOutput (OldAssignedGroupID, NewAssignedGroupID)
					FROM usr.{{FormIdent}} AS itsReq
					LEFT JOIN dbo.FolderTree AS fot ON fot.Ident = COALESCE(itsReq.ITSMCategoryLevel5Ident, itsReq.ITSMCategoryLevel4Ident, itsReq.ITSMCategoryLevel3Ident, itsReq.ITSMCategoryLevel2Ident)
					LEFT JOIN dbo.Folder AS fol ON fol.ID = fot.FolderID
					LEFT JOIN usr.ITSMCategory AS itsCat ON itsCat.ID = fol.TableID AND fol.FormIdent = 'ITSMCategory'
					OUTER APPLY (
						SELECT TOP(1) *
						FROM usr.ITSM_GetAllowedGroupByFolderTreeAndPermission (COALESCE(itsReq.ITSMCategoryLevel5Ident, itsReq.ITSMCategoryLevel4Ident, itsReq.ITSMCategoryLevel3Ident, itsReq.ITSMCategoryLevel2Ident),@PermissionIDs)
					) AS itsGagbttap
					WHERE
						itsReq.ID = @ID
						AND itsReq.[State] = 110
						AND itsReq.AssignedGroupID IS NULL

					IF EXISTS(
						SELECT NULL
						FROM @UpdateOutput
						WHERE ISNULL(OldAssignedGroupID, -1) != ISNULL(NewAssignedGroupID, -1)
					) BEGIN

						DECLARE @LastHistoryID INT = usr.ITSM_GetLastHistoryID_ByFormIdentTableIDHistoryTypeIDAccountID('{{FormIdent}}', @ID, 'Save', @UserID)

						IF @LastHistoryID IS NOT NULL BEGIN

							DECLARE
								@OldAssignedGroupID VARCHAR(MAX)
								,@NewAssignedGroupID VARCHAR(MAX)

							SELECT
								@OldAssignedGroupID = ISNULL(CAST(OldAssignedGroupID AS VARCHAR(MAX)), '')
								,@NewAssignedGroupID = ISNULL(CAST(NewAssignedGroupID AS VARCHAR(MAX)), '')
							FROM @UpdateOutput

							EXEC usr.ITSM_HistoryDataInsert @LastHistoryID, 'AssignedGroupID', @OldAssignedGroupID, @NewAssignedGroupID

						END

					END

				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
				</Parameters>
			</DataSource>
		</Action>

	</Contribution>

</Feature>
