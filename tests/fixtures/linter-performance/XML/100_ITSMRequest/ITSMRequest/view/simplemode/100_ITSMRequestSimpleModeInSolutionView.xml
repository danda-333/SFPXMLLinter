    <SQL><![CDATA[

      DECLARE @WorkFlowStates TABLE ([Value] INT, [Badge] VARCHAR(255))
      INSERT INTO @WorkFlowStates
      SELECT itsGwfs.[Value], CONCAT('<span class="badge badge-', itsGwfs.SimpleModeColorCssClass, '">', usr.GetResourceText(itsGwfs.SimpleModeTitleResourceKey, @UserLanguageID), '</span>') AS [Badge]
      FROM usr.ITSM_GetWorkFlowState ('ITSMRequestWorkFlow') AS itsGwfs

        SELECT *
        FROM (
          SELECT *, #ROWNUM#
          FROM (
            SELECT
              itsm.ID
              #ADDCOLUMN#
            FROM usr.ITSMRequest AS itsm
            INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
            #ADDFROM#
            WHERE
              itsm.[State] NOT IN (@DeletedState, @ClosedState, @ResolvedState)
              AND (
                (
                  ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter|]#
                )
                OR
                (
                  ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter,ITSMAuthor|]#
                )
                OR
                (
                  #PERMISSION[ITSMRequest(itsm)]#
                )
              ) #FILTER#
          ) AS tbl
        ) AS tbl
        WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
