    <SQL><![CDATA[

      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMRequest AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] != @DeletedState
            AND (
              (
                ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter|]#
              )
              OR
              (
                ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter,ITSMAuthor|]#
              )
              OR
              (
                #PERMISSION[ITSMRequest(itsm)]#
              )
            ) #FILTER# #DYNAMICWHERE#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
    <Parameters>
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StateValue" ConstantType="LocalVariable" DataType="Number">
        <dsp:FilterConditions>
          <dsp:DataSource>
            <dsp:SQL>
              itsm.[State] = @StateValue
            </dsp:SQL>
          </dsp:DataSource>
        </dsp:FilterConditions>
      </dsp:Parameter>
    </Parameters>
  </DataSource>

  <CountDataSource>
    <SQL><![CDATA[

      SELECT COUNT(itsm.ID)
      FROM usr.ITSMRequest AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] != @DeletedState
        AND (
          (
            ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter|]#
          )
          OR
          (
            ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMRequest(itsm)|ITSMRequestReporter,ITSMAuthor|]#
          )
          OR
          (
            #PERMISSION[ITSMRequest(itsm)]#
          )
        ) #FILTER# #DYNAMICWHERE#
    ]]></SQL>
    <Parameters>
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StateValue" ConstantType="LocalVariable" DataType="Number">
