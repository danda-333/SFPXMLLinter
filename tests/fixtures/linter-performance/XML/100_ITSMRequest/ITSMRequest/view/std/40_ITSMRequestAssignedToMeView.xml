        <Froms>
        </Froms>
        <SQL><![CDATA[

          SELECT *
          FROM (
            SELECT *, #ROWNUM#
            FROM (
              SELECT
                itsm.ID
                #ADDCOLUMN#
              FROM usr.ITSMRequest AS itsm
              INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
              #ADDFROM#
              WHERE
                itsm.[State] NOT IN (@DeletedState, @ClosedState, @ResolvedState, @ResolvedOperatorState)
                AND itsm.AssignedAccountID = @UserID
                AND #PERMISSION[ITSMRequest(itsm)]# #FILTER#
            ) AS tbl
          ) AS tbl
          WHERE RowNum BETWEEN @StartPage AND @EndPage

        ]]></SQL>
        <Parameters>
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" ConstantType="UserID" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="200" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedState" DataType="Number" Value="160" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedOperatorState" DataType="Number" Value="155" />
        </Parameters>
