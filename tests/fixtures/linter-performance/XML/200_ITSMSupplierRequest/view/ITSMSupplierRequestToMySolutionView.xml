  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMSupplierRequest AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] NOT IN (@DeletedState,@ClosedState)
        AND
        (
          (itsm.State IN (@SentToSupplier,@SolutionAssigned) AND #PERMISSION[ITSMRelease(itsm)|ITSMSupplier|]#)
          OR
          (
            itsm.State IN (@ReturnedForMoreInfo,@Suspended,@Resolved)
            AND
            (
              ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter|]#
            )
            OR
            (
              ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter,ITSMAuthor|]#
            )
          )
        ) #FILTER#
    ]]></SQL>
