                #ADDCOLUMN#
              FROM usr.ITSMSupplierRequest AS itsm
              INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
              #ADDFROM#
              WHERE
                itsm.[State] NOT IN (@DeletedState,@ClosedState)
                AND
                (
                  (itsm.State IN (@SentToSupplier,@SolutionAssigned) AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplier|]#)
                  OR
                  (
                    itsm.State IN (@ReturnedForMoreInfo,@Suspended,@Resolved)
                    AND
                    (
                      ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter|]#
                    )
                    OR
                    (
                      ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter,ITSMAuthor|]#
                    )
                  )
                ) #FILTER#
            ) AS tbl
          ) AS tbl
          WHERE RowNum BETWEEN @StartPage AND @EndPage
        ]]></SQL>
        <Parameters>
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SentToSupplier" DataType="Number" Value="10" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ReturnedForMoreInfo" DataType="Number" Value="20" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionAssigned" DataType="Number" Value="30" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="Suspended" DataType="Number" Value="40" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="Resolved" DataType="Number" Value="50" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="60" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" />
        </Parameters>
      </DataSource>
    </Section>
  </Sections>

</DataView>