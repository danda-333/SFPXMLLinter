		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT
            itsReq.ID
            #ADDCOLUMN#
          FROM usr.ITSMISToProductionEvidence AS itsReq
          INNER JOIN dbo.Account AS accCreator ON accCreator.ID = itsReq.AccountID
          #ADDFROM#
          WHERE
            itsReq.[State] = @OperationClosedState
            AND #PERMISSION[ITSMISToProductionEvidence(itsReq)]#
            #FILTER#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
