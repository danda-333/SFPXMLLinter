  <Definition>
    <States>
      <State Value="0" TitleResourceKey="Deleted_ITSM" ColorCssClass="danger" />
      <State Value="1" TitleResourceKey="New_ITSM" ColorCssClass="warning" />
      <State Value="10" TitleResourceKey="Categorization_ITSM" ColorCssClass="warning" />
      <State Value="20" TitleResourceKey="InputControlByOperator_ITSM" ColorCssClass="warning" />
      <State Value="30" TitleResourceKey="ReturnedForMoreInfo_ITSM" ColorCssClass="secondary" />
      <State Value="40" TitleResourceKey="AssignedToMyTeam_ITSM" ColorCssClass="success" />
      <State Value="50" TitleResourceKey="InProgress_ITSM" ColorCssClass="success" />
      <State Value="60" TitleResourceKey="SuspendedSLARunning_ITSM" ColorCssClass="success" />
      <State Value="70" TitleResourceKey="SuspendedForReview_ITSM" ColorCssClass="warning" />
      <State Value="80" TitleResourceKey="SuspendedSLAStopped_ITSM" ColorCssClass="danger" />
      <State Value="90" TitleResourceKey="ToSolutionCheck_ITSM" ColorCssClass="primary" />
      <State Value="100" TitleResourceKey="SolutionCheck_ITSM" ColorCssClass="primary" />
      <State Value="110" TitleResourceKey="SolutionRejected_ITSM" ColorCssClass="warning" />
      <State Value="120" TitleResourceKey="IncidentEvaluation_ITSM" ColorCssClass="warning" />
      <State Value="200" TitleResourceKey="Closed_ITSM" ColorCssClass="dark" IsOutOfSLA="true" />

      <State Value="130" TitleResourceKey="OperatorSolutionCheck_ITSM" ColorCssClass="primary" />
    </States>
  </Definition>

