        <SQL><![CDATA[
          SELECT *
          FROM (
            SELECT *, #ROWNUM#
            FROM (
              SELECT
                itsm.ID
                #ADDCOLUMN#
              FROM usr.ITSMChange AS itsm
              INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
              #ADDFROM#
              WHERE
                itsm.[State] != @DeletedState
                AND (
                  (
                    ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter|]#
                  )
                  OR
                  (
                    ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter,ITSMAuthor|]#
                  )
                  OR
                  (
                    #PERMISSION[ITSMChange(itsm)]#
                  )
                ) #FILTER# #DYNAMICWHERE#
            ) AS tbl
          ) AS tbl
          WHERE RowNum BETWEEN @StartPage AND @EndPage
        ]]></SQL>
        <Parameters>
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="TypeIdent" ConstantType="LocalVariable" DataType="String">
            <dsp:FilterConditions>
              <dsp:DataSource>
                <dsp:SQL>
                  (itsm.[State] = @TypeIdent)
                </dsp:SQL>
              </dsp:DataSource>
            </dsp:FilterConditions>
          </dsp:Parameter>
        </Parameters>
      </DataSource>
