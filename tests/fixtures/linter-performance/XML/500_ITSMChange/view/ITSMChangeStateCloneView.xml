    <dws:Setting xsi:type="dws:CloneDataViewSetting">
      <dws:DataSource>
        <dws:SQL>
          SELECT
            CONCAT('ITSMChange', REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View')) AS Ident
            ,CONCAT('ITSMChange_',REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View_ITSM')) AS TitleResourceKey
            ,wfState.[Value] AS TypeIdent
            ,200 + wfState.Value AS Priority
            ,wfState.ColorCssClass AS CountColorCssClass
          FROM usr.ITSMGetWorkFlowState('ITSMChangeWorkFlow') AS wfState
          WHERE Value NOT IN (0,1)
          ORDER BY wfState.Value ASC
        </dws:SQL>
        <dws:Parameters>
