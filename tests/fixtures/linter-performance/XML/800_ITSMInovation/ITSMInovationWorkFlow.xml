  <Definition>
    <States>
      <State Value="0" TitleResourceKey="Deleted_ITSM" ColorCssClass="danger" /> <!--Deleted-->
      <State Value="1" TitleResourceKey="New_ITSM" ColorCssClass="warning" /> <!--New-->
      <State Value="2" TitleResourceKey="Saved_ITSM" ColorCssClass="warning" /> <!--Saved-->

      <State Value="10" TitleResourceKey="ToOperatorAssessment_ITSM" ColorCssClass="warning" /> <!--K posouzení námětu operátorem-->
      <State Value="20" TitleResourceKey="CompletenessCheck_ITSM" ColorCssClass="warning" /> <!--Kontrola úplnosti-->
      <State Value="30" TitleResourceKey="ForApproval_ITSM" ColorCssClass="warning" /> <!--Ke schválení-->
      <State Value="40" TitleResourceKey="ToCoordinator_ITSM" ColorCssClass="primary" /> <!--K předání koordinátorovi-->
      <State Value="50" TitleResourceKey="ForRealization_ITSM" ColorCssClass="success" /> <!--K realizaci-->
      <State Value="60" TitleResourceKey="InRealization_ITSM" ColorCssClass="success" /> <!--V realizaci-->
      <State Value="70" TitleResourceKey="ForClosure_ITSM" ColorCssClass="primary" /> <!--K uzavření-->
      <State Value="80" TitleResourceKey="Closed_ITSM" ColorCssClass="dark" /> <!--Uzavřeno-->
      <State Value="90" TitleResourceKey="Postponed_ITSM" ColorCssClass="danger" /> <!--Odloženo-->
    </States>
  </Definition>

