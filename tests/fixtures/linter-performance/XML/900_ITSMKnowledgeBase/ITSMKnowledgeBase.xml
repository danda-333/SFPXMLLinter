<?xml version="1.0" encoding="utf-8"?>
<Form xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" Ident="ITSMKnowledgeBase" SegmentType="ITSMKnowledgeBaseSegment" PackageIdent="ITSMPackage" IsSubForm="true">
	<XMLDescription><![CDATA[
		Formulář: Znalostní báze
	]]></XMLDescription>
	<DataPermissions>
		<string>ITSMSettingAdmin</string> <!-- Static -->
	</DataPermissions>

	<CreatePermissions>
		<string>ITSMSettingAdmin</string>
	</CreatePermissions>

	<Buttons>
		<Button xsi:type="FormButton" Ident="SaveButton" TitleResourceKey="SaveButton_ITSM" IsSave="true" PlacementType="Top Bottom" ColorType="Primary" IconCssClass="icon-floppy-disk" IsVisible="false" />
		<Button xsi:type="FormButton" Ident="SaveWithoutValidationButton" TitleResourceKey="SaveButton_ITSM" IsSave="true" PlacementType="Top Bottom" ColorType="Primary" IconCssClass="icon-floppy-disk" IsVisible="false" IsSystem="true" />
		<Button xsi:type="FormButton" Ident="DeleteButton" TitleResourceKey="DeleteButton_ITSM" IsSave="false" ColorType="Danger" PlacementType="Top Bottom" IsVisible="false" IconCssClass="icon-bin2" />
	</Buttons>

	<Controls>
		<Control xsi:type="TextBoxControl" Ident="Title" DataType="String" TitleResourceKey="Title_ITSM" IsRequired="true" IsReadOnly="true" IsFullText="true" />
		<Control xsi:type="RichTextBoxControl" Ident="Content" DataType="String" Height="400" EnterType="P" TitleResourceKey="Content_ITSM" IsRequired="true" IsReadOnly="true" IsFullText="true" />

		<Control xsi:type="DropDownListControl" Ident="LanguageID" DataType="SmallNumber" TitleResourceKey="LanguageID_ITSM" IsRequired="true" IsReadOnly="true" IsFakeReadOnly="true">
			<DataBind>
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="Name" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT
						lan.ID,
						lan.[Name]
					FROM dbo.Language AS lan
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" DataType="Number" ConstantType="UserLanguageID" />
				</Parameters>
			</DataBind>
		</Control>

		<Control xsi:type="HiddenControl" Ident="SyncID" DataType="Number" />
		<Control xsi:type="HiddenControl" Ident="Guid" DataType="Guid" />
		<Control xsi:type="HiddenControl" Ident="TableID" DataType="Number" />
		<Control xsi:type="HiddenControl" Ident="FormIdent" DataType="String" />
	</Controls>

	<Sections>
		<Section xsi:type="ContentSection" Ident="BasicInformationSection" TitleResourceKey="BasicInformationSection_ITSM">
			<HTMLTemplate><![CDATA[

				<td>
					<div class="row">
						<div class="col-md-12">
							<div class="form-group">
								<ControlLabel ControlID="LanguageID" />
								<Control ID="LanguageID" />
							</div>
							<div class="form-group">
								<ControlLabel ControlID="Title" />
								<Control ID="Title" />
							</div>
							<div class="form-group">
								<ControlLabel ControlID="Content" />
								<Control ID="Content" />
							</div>
						</div>
					</div>
				</td>
			]]></HTMLTemplate>
		</Section>
	</Sections>
</Form>