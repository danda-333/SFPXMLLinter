<?xml version="1.0" encoding="utf-8"?>
<Form xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:fi="http://www.gappex.com/sfp/Form/Indexes" Ident="ITSMCategoryBreakdown" SegmentType="ITSMSettingSegment" PackageIdent="ITSMPackage">
	<DataPermissions>
		<string>ITSMSettingAdmin</string>
	</DataPermissions>
	<CreatePermissions>
		<string>ITSMSettingAdmin</string>
	</CreatePermissions>
	<Buttons>
		<Button xsi:type="FormButton" Ident="SaveButton" TitleResourceKey="SaveButton_ITSM" IsSave="true" PlacementType="Top Bottom" ColorType="Primary" IconCssClass="icon-floppy-disk" IsVisible="false" IsStopRedirect="true" />
		<Button xsi:type="FormButton" Ident="SaveAndExitButton" TitleResourceKey="SaveAndExitButton_ITSM" IsSave="true" PlacementType="Top Bottom" ColorType="Primary" IconCssClass="icon-floppy-disk" IsVisible="false" />
		<Button xsi:type="FormButton" Ident="DeleteButton" TitleResourceKey="DeleteButton_ITSM" IsSave="false" ColorType="Danger" PlacementType="Top Bottom" IsVisible="false" IconCssClass="icon-bin2">
			<Extensions>
				<Extension xsi:type="ConfirmDialogExtension" TitleResourceKey="DeleteDialogTitle_ITSM" DescriptionResourceKey="DeleteDialogDescription_ITSM" />
			</Extensions>
		</Button>
		<Button xsi:type="BackButton" Ident="BackButton" TitleResourceKey="BackButton_ITSM" IconCssClass="icon-undo2" PlacementType="Top Bottom" />
	</Buttons>
	<Controls>

		<Control xsi:type="TextBoxControl" Ident="BreakdownName" DataType="String" MaxLength="255" TitleResourceKey="BreakdownName_ITSM" IsRequired="true" IsReadOnly="true" />

		<Control xsi:type="FormDialogControl" Ident="ITSMCategoryBreakdownServiceFormDialogOpen" CreateButtonTitleResourceKey="AddITSMCategoryBreakdownServiceButton_ITSM" FormIdent="ITSMCategoryBreakdownServiceFormDialog">
			<Actions>
				<Action xsi:type="GenerateSubForm" ControlIdent="ITSMCategoryBreakdownSubForm" ActionStart="BeforeValidation">
					<DataSource>
						<Columns>
							<Column Ident="BreakdownFolderTreeIdent" DataBindType="Value" />
							<Column Ident="BreakdownFolderTreeIdentName" DataBindType="Title" ParentColumnIdent="BreakdownFolderTreeIdent" />
						</Columns>
						<SQL><![CDATA[
							SELECT
								ft.Ident AS BreakdownFolderTreeIdent
								,STUFF(
									(
										SELECT ' → ' + ftv.FolderName
										FROM (
											SELECT TOP (LEN(ft.Ident) / 7)
											ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n
											FROM sys.objects
										) x
										INNER JOIN dbo.FolderTreeView as ftv on ftv.Ident = LEFT(ft.Ident,(7*n))

										FOR XML PATH('')
								), 1, 3, '') AS BreakdownFolderTreeIdentName
							FROM dbo.FolderTree as ft
							INNER JOIN dbo.Folder as f on f.ID = ft.FolderID AND f.[State] = @StateOne
							WHERE
								ft.[Ident] IN (SELECT ID FROM @BreakdownFolderTreeIdent)
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="BreakdownFolderTreeIdent" DataType="VarCharList" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="StateOne" DataType="Number" Value="1" />
						</Parameters>
					</DataSource>
				</Action>
			</Actions>
		</Control>

		<Control xsi:type="SubFormControl" Ident="ITSMCategoryBreakdownSubForm" TextResourceKey="ITSMCategoryBreakdownSubForm_ITSM" FormIdent="ITSMCategoryBreakdownSubForm" IsSortable="true" SortableControlIdent="ApproveOrder" InsertButtonIdent="SaveButton" DeleteButtonIdent="DeleteButton" UpdateButtonIdent="SaveButton" IsReadOnly="true">
			<DataSource>
				<Columns>
					<Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" IsVisible="false" />
					<Column Ident="BreakdownFolderTreeIdent" TitleResourceKey="BreakdownFolderTreeIdent_ITSM" Width="70" />
					<Column xsi:type="DeleteColumn" Ident="ID" Width="10" />
				</Columns>
				<SQL><![CDATA[
					SELECT
						itsmSupConSF.ID
						,STUFF(
							(
								SELECT ' → ' + ftv.FolderName
								FROM (
									SELECT TOP (LEN(itsmSupConSF.BreakdownFolderTreeIdent) / 7)
									ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n
									FROM sys.objects
								) x
								INNER JOIN dbo.FolderTreeView as ftv on ftv.Ident = LEFT(itsmSupConSF.BreakdownFolderTreeIdent,(7*n))

								FOR XML PATH('')
						), 1, 3, '') AS BreakdownFolderTreeIdent
					FROM usr.ITSMCategoryBreakdownSubForm as itsmSupConSF
					WHERE
						itsmSupConSF.TableID = @ID
						AND itsmSupConSF.FormIdent = @ThisFormIdent
						AND itsmSupConSF.[State] != @DeletedState
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="ITSMCategoryBreakdown" />
				</Parameters>
			</DataSource>
		</Control>

	</Controls>
	<Sections>
		<Section xsi:type="ContentSection" Ident="BasicInformation" TitleResourceKey="BasicInformationSection_ITSM" IconCssClass="icon-bookmark">
			<HTMLTemplate><![CDATA[

				<style>
