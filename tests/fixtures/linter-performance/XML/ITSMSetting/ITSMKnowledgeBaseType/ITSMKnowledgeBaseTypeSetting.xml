		<Control xsi:type="HiddenControl" Ident="Guid" DataType="Guid" />

		<Control xsi:type="CheckBoxControl" Ident="IsActive" DataType="Bool" TitleResourceKey="IsActive_ITSM" LabelPlacementType="Right" Default="1" IsReadOnly="true" />
		<Control xsi:type="TextBoxControl" Ident="OrderValue" DataType="Number" TitleResourceKey="OrderValue_ITSM" IsReadOnly="true" />
		<!-- @Ignore ident-convention-lookup-control -->
		<Control xsi:type="AutoCompleteControl" Ident="IconCssClass" MaxLength="255" DataType="String" TitleResourceKey="IconCssClass_Utility" IsReadOnly="false" IsRequired="true">
			<DataBind DefaultTitleResourceKey="SelectValue_Utility" DefaultValue="">
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
					<Column Ident="Title" DataBindType="Title" />
				</Columns>
				<SQL>
					SELECT ico.[Key] AS [Value], CONCAT('<i class="mr-2 ', ico.[Key],'" style="width: 1rem; height: 1rem; border-radius: 50%; display: inline-block; margin-bottom: -2px;"></i>', ico.[Key]) AS [Title]
					FROM usr.Icon AS ico
					WHERE
						ico.[Group] = 'ph'
						AND (
							ico.[Key] LIKE '%' + @IconCssClass + '%'
							OR @IconCssClass IS NULL
						)

				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IconCssClass" DataType="String" />
				</Parameters>
			</DataBind>
			<SelectedDataBind>
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
					<Column Ident="Title" DataBindType="Title" />
				</Columns>
				<SQL>
					SELECT @IconCssClass AS [Value], CONCAT('<i class="mr-2 ', @IconCssClass,'" style="width: 1rem; height: 1rem; border-radius: 50%; display: inline-block; margin-bottom: -2px;"></i>', @IconCssClass) AS [Title]
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IconCssClass" DataType="String" />
				</Parameters>
			</SelectedDataBind>
			<DefaultDataSource>
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
				</Columns>
				<SQL>
					SELECT 'ph-file' AS [Value]
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="OriginalHistoryTypeID" DataType="String" />
				</Parameters>
			</DefaultDataSource>
		</Control>

		<!-- @Ignore ident-convention-lookup-control -->
		<Control xsi:type="AutoCompleteControl" Ident="ColorCssClass" MaxLength="255" DataType="String" TitleResourceKey="ColorCssClass_Utility" IsReadOnly="false" IsRequired="true">
			<DataBind DefaultTitleResourceKey="SelectValue_Utility" DefaultValue="">
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
					<Column Ident="Title" DataBindType="Title" />
				</Columns>
				<SQL>
					DECLARE @SFPColors TABLE (ColorCssClass NVARCHAR(255));

							  INSERT INTO @SFPColors (ColorCssClass)
							  VALUES
								  ('primary-300'),('primary-400'),('primary'),('primary-600'),('primary-700'),('primary-800')
								  ,('danger-300'),('danger-400'),('danger'),('danger-600'),('danger-700'),('danger-800')
								  ,('success-300'),('success-400'),('success'),('success-600'),('success-700'),('success-800')
								  ,('warning-300'),('warning-400'),('warning'),('warning-600'),('warning-700'),('warning-800')
								  ,('info-300'),('info-400'),('info'),('info-600'),('info-700'),('info-800')
								  ,('pink-300'),('pink-400'),('pink'),('pink-600'),('pink-700'),('pink-800')
								  ,('violet-300'),('violet-400'),('violet'),('violet-600'),('violet-700'),('violet-800')
								  ,('purple-300'),('purple-400'),('purple'),('purple-600'),('purple-700'),('purple-800')
								  ,('indigo-300'),('indigo-400'),('indigo'),('indigo-600'),('indigo-700'),('indigo-800')
								  ,('blue-300'),('blue-400'),('blue'),('blue-600'),('blue-700'),('blue-800')
								  ,('teal-300'),('teal-400'),('teal'),('teal-600'),('teal-700'),('teal-800')
								  ,('green-300'),('green-400'),('green'),('green-600'),('green-700'),('green-800')
								  ,('orange-300'),('orange-400'),('orange'),('orange-600'),('orange-700'),('orange-800')
								  ,('brown-300'),('brown-400'),('brown'),('brown-600'),('brown-700'),('brown-800')
								  ,('grey-300'),('grey-400'),('grey'),('grey-600'),('grey-700'),('grey-800')
								  ,('slate-300'),('slate-400'),('slate'),('slate-600'),('slate-700'),('slate-800')

							  SELECT ColorCssClass AS [Value], CONCAT('<span class="mr-2 bg-', ColorCssClass,'" style="width: 1rem; height: 1rem; border-radius: 50%; display: inline-block; margin-bottom: -2px;"></span>', ColorCssClass) AS [Title]
							  FROM @SFPColors
							  WHERE
								  ColorCssClass LIKE '%' + @ColorCssClass + '%'
								  OR @ColorCssClass IS NULL

				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ColorCssClass" DataType="String" />
				</Parameters>
			</DataBind>
			<SelectedDataBind>
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
					<Column Ident="Title" DataBindType="Title" />
				</Columns>
				<SQL>
					SELECT @ColorCssClass AS [Value], CONCAT('<span class="mr-2 bg-', @ColorCssClass,'" style="width: 1rem; height: 1rem; border-radius: 50%; display: inline-block; margin-bottom: -2px;"></span>', @ColorCssClass) AS [Title]
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ColorCssClass" DataType="String" />
				</Parameters>
			</SelectedDataBind>
			<DefaultDataSource>
				<Columns>
					<Column Ident="Value" DataBindType="Value" />
				</Columns>
				<SQL>
					SELECT 'primary' AS [Value]
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="OriginalHistoryTypeID" DataType="String" />
				</Parameters>
			</DefaultDataSource>
		</Control>

		<Control xsi:type="TextBoxControl" Ident="FunctionalKey" DataType="String" TitleResourceKey="FunctionalKey_ITSM" IsReadOnly="true" />

		<Control xsi:type="InlineSubFormControl" Ident="ITSMKnowledgeBaseType" TextResourceKey="ITSMKnowledgeBaseType_ITSM" FormIdent="ITSMKnowledgeBaseType" InsertButtonIdent="SaveButton" DeleteButtonIdent="DeleteButton" UpdateButtonIdent="SaveButton" IsReadOnly="true">
			<DataSource>
				<Columns>
					<Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" IsVisible="false" />
					<Column Ident="LanguageID" TitleResourceKey="LanguageID_ITSM" Width="20" />
					<Column Ident="TextValue" TitleResourceKey="TextValue_ITSM" Width="80" />
				</Columns>
				<SQL><![CDATA[
					SELECT
						ISNULL(dial.ID, (ROW_NUMBER() OVER (ORDER BY dial.ID ASC)) * -1) AS ID,
						dial.TextValue,
						lan.ID AS LanguageID
					FROM dbo.[Language] AS lan
					LEFT JOIN (
						SELECT
							dial.ID,
							dial.TextValue,
							dial.LanguageID
						FROM usr.ITSMKnowledgeBaseTypeSetting AS dialSetting
						LEFT JOIN usr.ITSMKnowledgeBaseType AS dial
							ON dial.[State] != @DeletedState
							AND dial.Guid = dialSetting.Guid
						WHERE dialSetting.ID = @ID
					) AS dial
						ON dial.LanguageID = lan.ID
					ORDER BY lan.ID ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
				</Parameters>
			</DataSource>
		</Control>

		<Control xsi:type="TimeLineControl" Ident="TimeLine" TitleResourceKey="TimeLine_ITSM" SortType="DESC">
			<HistoryTypes>
				<string>Create</string>
				<string>ChangeState</string>
			</HistoryTypes>
		</Control>
	</Controls>

