<?xml version="1.0" encoding="utf-8"?>
<Component xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:wffc="http://www.gappex.com/sfp/WorkFlow/FormControl" xmlns:fi="http://www.gappex.com/sfp/Form/Indexes" xmlns:fcs="http://www.gappex.com/sfp/Form/Control/Settings" xmlns:dsf="http://www.gappex.com/sfp/DataSource/Froms" xmlns:dws="http://www.gappex.com/sfp/DataView/Settings" xmlns:dvs="http://www.gappex.com/sfp/DataView/Settings" xmlns:fccom="http://www.gappex.com/sfp/Form/Control/Communication">

	<Section Root="Form" Name="Controls" TargetXPath="//Form/Controls" Insert="append">
		<Control xsi:type="CommunicationControl" Ident="Communication" Height="400" DataType="String" IsVisible="false" IsReadOnly="true" TitleResourceKey="Communication_ITSM">
			<SettingPermissions>
				<SettingPermission Ident="InternalMessage" IsChecked="true" TitleResourceKey="InternalMessage_ITSM" IconCssClass="icon-user" ColorCssClass="primary">
					<VisiblePermissions>
						<string>ITSMAuthor</string>
						<string>ITSMSpecialist</string>
						<string>ITSMOperator</string>
					</VisiblePermissions>
				</SettingPermission>
				<SettingPermission Ident="ExternalMessage" IsChecked="false" TitleResourceKey="ExternalMessage_ITSM" IconCssClass="icon-user" ColorCssClass="danger">
					<VisiblePermissions>
						<string>ITSMIncidentReporter</string>
						<string>ITSMIncidentSharedReporter</string>
					</VisiblePermissions>
				</SettingPermission>
			</SettingPermissions>
			<Settings>
				<fcs:Setting xsi:type="fcs:PlacementPermissionSetting" PlacementType="Left" Permission="ITSMIncidentReporter" />
			</Settings>
			<TimeLineDataBind TransformType="Copy" />
		</Control>

		<Control xsi:type="CommunicationControl" Ident="DialogCommunication" Height="400" DataType="String" TitleResourceKey="Communication_ITSM">
			<!-- <SettingPermissions>
				<SettingPermission Ident="InternalMessage" IsChecked="true" TitleResourceKey="InternalMessage_ITSM" IconCssClass="icon-user" ColorCssClass="primary">
					<VisiblePermissions>
						<string>ITSMAuthor</string>
						<string>ITSMSpecialist</string>
						<string>ITSMOperator</string>
					</VisiblePermissions>
				</SettingPermission>
				<SettingPermission Ident="ExternalMessage" IsChecked="false" TitleResourceKey="ExternalMessage_ITSM" IconCssClass="icon-user" ColorCssClass="danger">
					<VisiblePermissions>
						<string>ITSMIncidentReporter</string>
						<string>ITSMIncidentSharedReporter</string>
					</VisiblePermissions>
				</SettingPermission>
			</SettingPermissions> -->
			<Settings>
				<fcs:Setting xsi:type="fcs:PlacementPermissionSetting" PlacementType="Left" Permission="ITSMIncidentReporter" />
			</Settings>
			<TimeLineDataBind TransformType="Copy" />
		</Control>

		<Control xsi:type="CommunicationListControl" Ident="CommunicationList" TitleResourceKey="CommunicationList_ITSM" CommunicationControlIdent="Communication" IsVisible="false">
			<OtherSource>
				<SQL>
					SELECT c.ID 
					FROM dbo.Communication as c 
					WHERE c.TableID = @ID AND c.FormIdent = @FormIdent AND c.ControlIdent = @ControlIdent
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number"/>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="150" Value="{{FormIdent}}"/>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ControlIdent" DataType="String" MaxLength="150" Value="DialogCommunication"/>
				</Parameters>
			</OtherSource>
		</Control>

		<Control xsi:type="PlaceHolderControl" Ident="CommunicationCardPlaceHolder" IsVisible="false"/>
		<Control xsi:type="PlaceHolderControl" Ident="DialogCommunicationRequiredPlaceHolder" IsVisible="false"/>
	</Section>

	<Section Root="Form" Name="Html" Insert="placeholder">
		<Control ID="CommunicationCardPlaceHolder">
			<div class="row">
				<div class="col-md-12">
					<div class="card">
						<div class="card-header bg-white header-elements-inline">
							<h6 class="card-title">[#Communication_ITSM#]</h6>
							<div class="header-elements">
								<div class="list-icons">
									<a class="list-icons-item" data-action="collapse" />
								</div>
							</div>
						</div>
						<div class="card-body">
							<div class="row">
								<div class="col-md-12">
									<div class="form-group">
										<Control ID="Communication" />
									</div>
								</div>
								<div class="col-md-12">
									<div class="form-group">
										<Control ID="CommunicationList" />
									</div>
								</div>
							</div>
						</div>
					</div>
				</div>
			</div>
		</Control>
	</Section>

	<Section Root="WorkFlow" Name="ControlShareCodes" TargetXPath="//WorkFlow/ControlShareCodes" Insert="append">

		<ControlShareCode Ident="ShowCommunicationControlShare">
			<Controls>

				<FormControl Ident="CommunicationList" IsVisible="true" />
				<FormControl Ident="CommunicationCardPlaceHolder" IsVisible="true" />

			</Controls>
		</ControlShareCode> <!-- <FormControl xsi:type="ShareCodeControl" Ident="ShowCommunicationControlShare" /> -->

		<ControlShareCode Ident="EnableCommunicationControlShare">
			<Controls>

				<FormControl Ident="Communication" IsVisible="true" IsReadOnly="false"/>
				<FormControl Ident="CommunicationList" IsVisible="true" />
				<FormControl Ident="CommunicationCardPlaceHolder" IsVisible="true" />

			</Controls>
		</ControlShareCode> <!-- <FormControl xsi:type="ShareCodeControl" Ident="EnableCommunicationControlShare" /> -->

		<ControlShareCode Ident="EnableRequiredDialogCommunicationControlShare">
			<Controls>
				<FormControl xsi:type="IFControl">
          <Condition>
						<SQL>
							SELECT IIF( 
								ISNULL(@Communication, '') = ''
								AND NOT EXISTS(
									SELECT NULL
									FROM usr.{{FormIdent}} AS tic
									OUTER APPLY (
										SELECT TOP(1) his.*
										FROM dbo.History AS his
										WHERE  
											his.TableID = tic.ID
											AND his.FormIdent = '{{FormIdent}}'
											AND his.HistoryTypeID = 'ChangeState'
										ORDER BY his.CreateDate DESC
									) AS hisLast
									INNER JOIN dbo.Communication AS com 
										ON com.TableID = tic.ID
										AND com.FormIdent = '{{FormIdent}}'
										AND com.CreateDate >= ISNULL(hisLast.CreateDate, tic.CreateDate)
										AND com.AccountID = @UserID
										AND com.CommunicationTypeID = 'Comment_ITSM'
									WHERE tic.ID = @ID
								)
							, 1, 0)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Communication" SetDataType="ActualData" DataType="String"  />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</Condition>
          <TrueControls>
            <FormControl Ident="DialogCommunicationRequiredPlaceHolder" IsVisible="true" />
          </TrueControls>
        </FormControl>
			</Controls>
		</ControlShareCode> <!-- <FormControl xsi:type="ShareCodeControl" Ident="EnableRequiredDialogCommunicationControlShare" /> -->
		
	</Section>

	<Section Root="WorkFlow" Name="//WorkFlow/Steps/Step/Groups/Group/Controls" TargetXPath="//WorkFlow/Steps/Step/Groups/Group/Controls" Insert="append" AllowMultipleInserts="true">

		<FormControl xsi:type="ShareCodeControl" Ident="EnableRequiredDialogCommunicationControlShare" />
		
	</Section>

	<Section Root="WorkFlow" Name="ActionShareCodes" TargetXPath="//WorkFlow/ActionShareCodes" Insert="append">

		<ActionShareCode Ident="DialogCommunicationRequiredActionShare">
			<Actions>
				
				<Action xsi:type="IF" ActionStart="BeforeValidation">
					<Condition>
						<SQL>
							SELECT IIF( 
								ISNULL(@Communication, '') = ''
								AND NOT EXISTS(
									SELECT NULL
									FROM usr.{{FormIdent}} AS tic
									OUTER APPLY (
										SELECT TOP(1) his.*
										FROM dbo.History AS his
										WHERE  
											his.TableID = tic.ID
											AND his.FormIdent = '{{FormIdent}}'
											AND his.HistoryTypeID = 'ChangeState'
										ORDER BY his.CreateDate DESC
									) AS hisLast
									INNER JOIN dbo.Communication AS com 
										ON com.TableID = tic.ID
										AND com.FormIdent = '{{FormIdent}}'
										AND com.CreateDate >= ISNULL(hisLast.CreateDate, tic.CreateDate)
										AND com.AccountID = @UserID
										AND com.CommunicationTypeID = 'Comment_ITSM'
									WHERE tic.ID = @ID
								)
							, 1, 0)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Communication" SetDataType="ActualData" DataType="String"  />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="Required" ActionStart="BeforeValidation">
							<Idents>
								<string>DialogCommunication</string>
							</Idents>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

			</Actions>
		</ActionShareCode> <!-- <Action xsi:type="ShareCode" Ident="DialogCommunicationRequiredActionShare" /> -->
		
	</Section>

	<Section Root="WorkFlow" Name="SaveDialogCommunicationAction" Insert="placeholder">

		<GeneratorSnippet UseGenerator="Common/WorkFlow/LiftActionsToShareCode" ShareCodeIdentPostFix="{{ShareCodeIdentPostFix}}">
			<Action xsi:type="Communication" ControlIdent="DialogCommunication" Type="{{CommunicationTypeID}}" ActionStart="AfterSave" />

			<Action xsi:type="ActionTrigger" Ident="SaveDialogCommunicationAction" ActionStart="AfterSave">
				<DataSource>
					<SQL><![CDATA[

						DECLARE @CommunicationID INT

						SELECT @CommunicationID = com.ID
						FROM dbo.Communication AS com
						WHERE 
							com.FormIdent = '{{FormIdent}}'
							AND com.ControlIdent = 'DialogCommunication'
							AND com.TableID = @ID
							AND com.AccountID = @UserID
						
						IF @CommunicationID IS NOT NULL BEGIN

							UPDATE com
							SET ControlIdent = 'Communication'
							FROM dbo.Communication AS com
							WHERE com.ID = @CommunicationID

							DELETE FROM dbo.CommunicationPermission
							WHERE CommunicationID = @CommunicationID

							INSERT INTO dbo.CommunicationPermission (
								[CommunicationID]
								,[SettingIdent]
							)
							SELECT 
								[CommunicationID] = @CommunicationID
								,[SettingIdent] = 'InternalMessage'

							IF '{{IsExternalMessage}}' = 'true' 
								INSERT INTO dbo.CommunicationPermission (
									[CommunicationID]
									,[SettingIdent]
								)
								SELECT 
									[CommunicationID] = @CommunicationID
									,[SettingIdent] = 'ExternalMessage'

						END

					]]></SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="DialogCommunication" SetDataType="ActualData" DataType="String"  />
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
					</Parameters>
				</DataSource>
			</Action>
		</GeneratorSnippet>
		
	</Section>
	
</Component>
