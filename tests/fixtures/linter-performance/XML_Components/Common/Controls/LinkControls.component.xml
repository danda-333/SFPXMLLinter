											<ControlLabel ControlID="ITSMLinkSubForm" />
											<Control ID="ITSMLinkSubForm" />
										</div>
									</div>
								</div>

							</div>
						</div>

					</div>
				</div>

				<div class="row">
					<div class="col-md-12">

						<div class="card">
							<div class="card-header bg-white header-elements-inline">
								<h6 class="card-title">[#ITSMStructure_ITSM#]</h6>
								<div class="header-elements">
									<div class="list-icons">
										<a class="list-icons-item" data-action="collapse"></a>
									</div>
								</div>
							</div>
							<div class="card-body">

								<div class="row">
									<div class="col-md-4">
										<div class="form-group">
											<ControlLabel ControlID="ParentTableID" />
											<Control ID="ParentTableID" />
										</div>
									</div>
								</div>
								<div class="row">
									<div class="col-md-12">
										<div class="form-group datagrid-no-scroll">
											<Control ID="SubITSMDataGrid" />
										</div>
									</div>
								</div>

							</div>
						</div>

					</div>
