			</Idents>
		</Action>

	</Section>
	
	<Section Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">

		<Action xsi:type="IF" ActionStart="BeforeValidation">
      <Condition>
        <SQL><![CDATA[

          DECLARE @PermissionIDs dbo.ListNVarchar100Type;
					INSERT INTO @PermissionIDs VALUES ('ITSMOperator');

					DECLARE @LastITSMCategoryIdent VARCHAR(900) = @ITSMCategoryLevel2Ident;
          IF @IsShowCategoryLevel3 = 1
            SET @LastITSMCategoryIdent = @ITSMCategoryLevel3Ident
          IF @IsShowCategoryLevel4 = 1
            SET @LastITSMCategoryIdent = @ITSMCategoryLevel4Ident
          IF @IsShowCategoryLevel5 = 1
            SET @LastITSMCategoryIdent = @ITSMCategoryLevel5Ident

					SELECT IIF(
						EXISTS(
							SELECT NULL
							FROM usr.ITSM_GetAllowedFolderTreeByAccountAndPermissionAndSegmentType(@UserID,@FolderGroupSegmentIdent,'{{FormIdent}}Segment',@PermissionIDs)
							WHERE
								FolderTreeIdent = @LastITSMCategoryIdent
						)
						OR ISNULL(@ID, 0) != 0
					, 0, 1)

        ]]></SQL>
        <Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FolderGroupSegmentIdent" DataType="String" MaxLength="50" Value="ITSMCommonFolderGroup" />

					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsShowCategoryLevel3" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsShowCategoryLevel4" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsShowCategoryLevel5" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900"/>
        </Parameters>
      </Condition>
      <TrueActions>

				<Action xsi:type="IF" ActionStart="BeforeValidation">
					<Condition>
						<SQL><![CDATA[

							SELECT IIF(
								ISNULL(@Var_ButtonIdent, '') != 'SendToCategorizationButton'
							, 1, 0)

						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Var_ButtonIdent" DataType="String" />
						</Parameters>
					</Condition>
					<TrueActions>

						<Action xsi:type="ActionValue" Ident="ITSMEntryMethodTypeGuid_Update_Action" ControlIdent="ITSMEntryMethodTypeGuid" ActionStart="BeforeValidation">
							<DataSource>
								<SQL><![CDATA[

									SELECT CAST([GUID] AS VARCHAR(MAX)) AS ITSMEntryMethodTypeGuid
									FROM usr.ITSMEntryMethodTypeSetting
									WHERE FunctionalKey = 'itsm' AND [State] != @DeletedState

								]]></SQL>
								<Parameters>
									<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
								</Parameters>
							</DataSource>
						</Action>

					</TrueActions>
				</Action>

				<Action xsi:type="ActionValue" Ident="ReporterAccountID_Update_Action" ControlIdent="ReporterAccountID" ActionStart="BeforeValidation">
					<DataSource>
						<SQL><![CDATA[

							SELECT @UserID AS ReporterAccountID
							
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</DataSource>
				</Action>
				

      </TrueActions>
    </Action>

	</Section>

	
</Component>