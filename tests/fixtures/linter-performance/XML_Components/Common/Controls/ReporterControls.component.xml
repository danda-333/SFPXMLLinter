				</Dependencies>
				<Columns>
					<Column Ident="ReporterEmail" DataBindType="Value" />
				</Columns>
				<SQL><![CDATA[

					SELECT Email AS ReporterEmail
					FROM dbo.Account
					WHERE ID = @ReporterAccountID

					INSERT INTO ##TmpTbl ([Message]) SELECT CONCAT('ReporterEmail - ReporterAccountID: ', @ReporterAccountID)

