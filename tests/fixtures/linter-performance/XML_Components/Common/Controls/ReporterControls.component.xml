	<Section Root="Form" Name="Controls" TargetXPath="//Form/Controls" Insert="append">
		<Control xsi:type="AutoCompleteControl" Ident="ReporterAccountID" DataType="Number" TitleResourceKey="ReporterAccountID_ITSM" IsVisible="false" IsReadOnly="true" IsShowRequired="true">
			<EmptyDataBind Ident="ReporterAccountID_EmptyDataBind">
				<Dependencies>
					<string>ITSMCompanyIdent</string>
					<string>ITSMCategoryLevel2Ident</string>
					<string>ITSMCategoryLevel3Ident</string>
					<string>ITSMCategoryLevel4Ident</string>
					<string>ITSMCategoryLevel5Ident</string>
				</Dependencies>
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[

					DECLARE @PermissionIDs dbo.ListNVarchar100Type;
					INSERT INTO @PermissionIDs VALUES ('ITSMOperator');

					DECLARE @LastFolderTreeIdent VARCHAR(900) = COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent)
					
					IF EXISTS(
						SELECT NULL
						FROM usr.ITSM_GetAllowedFolderTreeByAccountAndPermissionAndSegmentType(@UserID,@FolderGroupSegmentIdent,'{{FormIdent}}Segment',@PermissionIDs)
						WHERE FolderTreeIdent = @LastFolderTreeIdent
					) BEGIN

						INSERT INTO @PermissionIDs VALUES ('ITSMAuthor')

						SELECT TOP(20) itsGaabftap.AccountID AS ID, itsGaabftap.AccountFullName AS FullName
						FROM usr.ITSM_GetAllowedAccountByFolderTreeAndPermission (@LastFolderTreeIdent, @PermissionIDs) AS itsGaabftap
					
					END ELSE BEGIN

						SELECT acc.ID, acc.FullName
						FROM dbo.Account AS acc
						WHERE acc.ID = @UserID

					END

				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FolderGroupSegmentIdent" DataType="String" MaxLength="50" Value="ITSMCommonFolderGroup" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsElevatedPermissionOrNotFirstState" DataType="Number" />
				</Parameters>
			</EmptyDataBind>
			<DataBind Ident="ReporterAccountID_DataBind" DefaultTitleResourceKey="SelectValue">
				<Dependencies>
					<string>ITSMCompanyIdent</string>
					<string>ITSMCategoryLevel2Ident</string>
					<string>ITSMCategoryLevel3Ident</string>
					<string>ITSMCategoryLevel4Ident</string>
					<string>ITSMCategoryLevel5Ident</string>
				</Dependencies>
				<Columns>
					<Column Ident="ID" DataBindType="Value"/>
					<Column Ident="FullName" DataBindType="Title"/>
				</Columns>
				<SQL><![CDATA[

					DECLARE @PermissionIDs dbo.ListNVarchar100Type;
					INSERT INTO @PermissionIDs VALUES ('ITSMOperator');

					DECLARE @LastFolderTreeIdent VARCHAR(900) = COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent)
					
					IF EXISTS(
						SELECT NULL
						FROM usr.ITSM_GetAllowedFolderTreeByAccountAndPermissionAndSegmentType(@UserID,@FolderGroupSegmentIdent,'{{FormIdent}}Segment',@PermissionIDs)
						WHERE FolderTreeIdent = @LastFolderTreeIdent
					) BEGIN

						INSERT INTO @PermissionIDs VALUES ('ITSMAuthor')

						SELECT itsGaabftap.AccountID AS ID, itsGaabftap.AccountFullName AS FullName
						FROM usr.ITSM_GetAllowedAccountByFolderTreeAndPermission (@LastFolderTreeIdent, @PermissionIDs) AS itsGaabftap
						WHERE itsGaabftap.AccountFullName LIKE @ReporterAccountID
					
					END ELSE BEGIN

						SELECT acc.ID, acc.FullName
						FROM dbo.Account AS acc
						WHERE acc.ID = @UserID

					END

				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ReporterAccountID" DataType="String" LikeType="Both"/>

					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FolderGroupSegmentIdent" DataType="String" MaxLength="50" Value="ITSMCommonFolderGroup" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
				</Parameters>
			</DataBind>
			<SelectedDataBind Ident="ReporterAccountID_SelectedDataBind">
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[

					SELECT acc.ID, acc.FullName
					FROM dbo.Account AS acc
					WHERE acc.ID = @ReporterAccountID

				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ReporterAccountID" DataType="Number" />

					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FolderGroupSegmentIdent" DataType="String" MaxLength="50" Value="ITSMCommonFolderGroup" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
				</Parameters>
			</SelectedDataBind>
			<DefaultDataSource Ident="ReporterAccountID_DefaultDataSource">
				<Columns>
					<Column Ident="ReporterAccountID" />
				</Columns>
				<SQL><![CDATA[

					SELECT @UserID AS ReporterAccountID

				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
				</Parameters>
			</DefaultDataSource>
			<DefaultDependencyDataBind Ident="ReporterAccountID_DefaultDependencyDataBind">
				<Dependencies>
					<string>ITSMCompanyIdent</string>
					<string>ITSMCategoryLevel2Ident</string>
					<string>ITSMCategoryLevel3Ident</string>
					<string>ITSMCategoryLevel4Ident</string>
					<string>ITSMCategoryLevel5Ident</string>
				</Dependencies>
				<Columns>
					<Column Ident="ID" DataBindType="Value"/>
					<Column Ident="FullName" DataBindType="Title"/>
					<!-- <Column Ident="Selected" DataBindType="Selected"/> -->
				</Columns>
				<SQL><![CDATA[

					DECLARE @PermissionIDs dbo.ListNVarchar100Type;
					INSERT INTO @PermissionIDs VALUES ('ITSMOperator');

					DECLARE @NewReporterAccountID INT

					DECLARE @LastFolderTreeIdent VARCHAR(900) = COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent)
					
					IF EXISTS(
						SELECT NULL
						FROM usr.ITSM_GetAllowedFolderTreeByAccountAndPermissionAndSegmentType(@UserID,@FolderGroupSegmentIdent,'{{FormIdent}}Segment',@PermissionIDs)
						WHERE FolderTreeIdent = @LastFolderTreeIdent
					) BEGIN

						INSERT INTO @PermissionIDs VALUES ('ITSMAuthor')

						SELECT @NewReporterAccountID = itsGaabftap.AccountID
						FROM usr.ITSM_GetAllowedAccountByFolderTreeAndPermission (@LastFolderTreeIdent, @PermissionIDs) AS itsGaabftap
						WHERE itsGaabftap.AccountID = @ReporterAccountID
					
					END

					IF @NewReporterAccountID IS  NULL
						SELECT @NewReporterAccountID = @UserID

					SELECT acc.ID, acc.FullName
					FROM dbo.Account AS acc
					WHERE acc.ID = @NewReporterAccountID
					
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ReporterAccountID" DataType="Number" SetDataType="SelectedValueData" />

					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FolderGroupSegmentIdent" DataType="String" MaxLength="50" Value="ITSMCommonFolderGroup" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
				</Parameters>
			</DefaultDependencyDataBind>
			<TimeLineDataBind TransformType="AutoQuery" DatabaseScheme="dbo" FormIdent="Account" KeyColumnIdent="ID" KeyColumnDataType="INT" TitleColumnIdent="FullName" TitleColumnDataType="VARCHAR(MAX)" />
		</Control>

		<Control xsi:type="TextBoxControl" Ident="ReporterEmail" DataType="String" TitleResourceKey="ReporterEmail_ITSM" IsVisible="false" IsReadOnly="true">
