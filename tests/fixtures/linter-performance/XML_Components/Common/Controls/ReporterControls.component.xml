		<!-- @Ignore ident-convention-lookup-control -->
		<Control xsi:type="DropDownListControl" Ident="ITSMEntryMethodTypeGuid" DataType="Guid" TitleResourceKey="ITSMEntryMethodTypeGuid_ITSM" IsReadOnly="true" IsShowRequired="true">
			<DataBind>
				<Columns>
					<Column Ident="Guid" DataBindType="Value" />
					<Column Ident="TextValue" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						dialsetting.Guid,
						dial.TextValue
					FROM usr.ITSMEntryMethodType AS dial
					INNER JOIN usr.ITSMEntryMethodTypeSetting AS dialsetting 
						ON dialsetting.Guid = dial.Guid
					WHERE 
						dial.LanguageID = @UserLanguageID
						AND dial.[State] != @DeletedState
					ORDER BY dial.OrderValue ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
				</Parameters>
			</DataBind>
			<DefaultDataSource>
				<Columns>
					<Column Ident="ITSMEntryMethodTypeGuid" />
				</Columns>
				<SQL><![CDATA[
					SELECT [GUID] AS ITSMEntryMethodTypeGuid
					FROM usr.ITSMEntryMethodTypeSetting
					WHERE FunctionalKey = 'user' AND [State] != @DeletedState
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0"/>
				</Parameters>
			</DefaultDataSource>
			<TimeLineDataBind TransformType="SQL" KeyColumnDataType="VARCHAR(MAX)" TitleColumnDataType="VARCHAR(MAX)">
				<SQL><![CDATA[
					SET @Result = (
						SELECT dial.TextValue
						FROM usr.ITSMEntryMethodType AS dial
							INNER JOIN usr.ITSMEntryMethodTypeSetting AS dialsetting 
								ON dialsetting.Guid = dial.Guid
							WHERE 
								dial.LanguageID = @UserLanguageID
								AND dial.[State] != 0
								AND CAST(dialsetting.Guid AS VARCHAR(MAX)) = @Value
					)
				]]></SQL>
			</TimeLineDataBind>
		</Control>

