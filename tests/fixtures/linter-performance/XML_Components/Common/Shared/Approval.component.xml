									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="String" />
								</Parameters>
							</DataSource>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

			</Actions>

		</ActionShareCode><!-- <Action xsi:type="ShareCode" Ident="ApproveActionShareCode" /> -->

    <ActionShareCode Ident="RejectActionShareCode">
			<Actions>

				<Action xsi:type="IF" ActionStart="BeforeValidation">
					<Condition>
						<SQL>
							SELECT IIF( 
								ISNULL(@Communication, '') = ''
								AND NOT EXISTS(
									SELECT NULL
									FROM usr.{{FormIdent}} AS tic
									OUTER APPLY (
										SELECT TOP(1) his.*
										FROM dbo.History AS his
										WHERE  
											his.TableID = tic.ID
											AND his.FormIdent = '{{FormIdent}}'
											AND his.HistoryTypeID = 'ChangeState'
										ORDER BY his.CreateDate DESC
									) AS hisLast
									INNER JOIN dbo.Communication AS com 
										ON com.TableID = tic.ID
										AND com.FormIdent = '{{FormIdent}}'
										AND com.CreateDate >= ISNULL(hisLast.CreateDate, tic.CreateDate)
										AND com.AccountID = @UserID
										AND com.CommunicationTypeID = 'Comment_ITSM'
									WHERE tic.ID = @ID
								)
							, 1, 0)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Communication" SetDataType="ActualData" DataType="String"  />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="Required" ActionStart="BeforeValidation">
							<Idents>
								<string>DialogCommunication</string>
							</Idents>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

				<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterSave">
					<DataSource>
						<SQL>

							UPDATE usr.ITSMApproval
							SET IsApproved = @ApprovedState
							, ApproveDateTime = GETDATE()
							, ApprovedAccountID = @UserID
							, ApproveComment = @DialogCommunication
							WHERE 
								TableID = @ID
								AND FormIdent = @FormIdent
								AND ApproveRoundGUID = @ActualApproveRoundGuid
								AND ApproveOrder = (
									SELECT MIN(sub.ApproveOrder)
									FROM usr.ITSMApproval sub
									WHERE sub.FormIdent = @FormIdent
										AND sub.TableID = @ID
										AND sub.ApproveRoundGUID = @ActualApproveRoundGuid
										AND sub.State != 0
										AND sub.IsApproved IS NULL
								)
								AND IsApproved IS NULL
								AND State != 0

						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="State" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ApprovedState" DataType="Number" Value="0"/>
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="DialogCommunication" DataType="String" />
						</Parameters>
					</DataSource>
				</Action>

				<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterPermission">
					<DataSource>
						<SQL>

							UPDATE usr.{{FormIdent}}
							SET ActualApproveRoundGuid = NEWID()
							WHERE ID = @ID

						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						</Parameters>
					</DataSource>
				</Action>
				
				<Action xsi:type="GenerateForm" Ident="GenerateITSMApprovalRequestFakeSubForm" FormIdent="ITSMApprovalRequestFakeSubForm" ActionStart="AfterPermission" ButtonIdent="SaveButton">
					<Mappings>
						<Mapping FromIdent="TableID" ToIdent="TableID"/>
						<Mapping FromIdent="FormIdent" ToIdent="FormIdent"/>
						<Mapping FromIdent="ApproveOrder" ToIdent="ApproveOrder"/>
						<Mapping FromIdent="ApproverType" ToIdent="ApproverType"/>
						<Mapping FromIdent="ApproverGroupID" ToIdent="ApproverGroupID"/>
						<Mapping FromIdent="ApproverAccountID" ToIdent="ApproverAccountID"/>
						<Mapping FromIdent="ApproveRoundGUID" ToIdent="ApproveRoundGUID"/>
					</Mappings>
					<DataSource>
						<SQL><![CDATA[
							DECLARE @LastFolderTree VARCHAR(900);

							DECLARE @NewApproveRoundGUID uniqueidentifier = (
								SELECT ActualApproveRoundGuid
								FROM usr.{{FormIdent}}
								WHERE ID = @ID
							)

							SET @LastFolderTree = COALESCE(
								CASE WHEN @IsShowCategoryLevel5 = 1 THEN NULLIF(@ITSMCategoryLevel5Ident, '') ELSE NULL END,
								NULLIF(@ITSMCategoryLevel4Ident, ''),
								NULLIF(@ITSMCategoryLevel3Ident, ''),
								NULLIF(@ITSMCategoryLevel2Ident, ''),
								NULLIF(@ITSMCompanyIdent, '')
							);

							SELECT
								@ID AS TableID,
								@FormIdent AS FormIdent,
								appsf.ApproveOrder AS ApproveOrder,
								appsf.ApproverType,
								appsf.ApproverGroupID,
								appsf.ApproverAccountID,
								@NewApproveRoundGUID AS ApproveRoundGUID
							FROM usr.ITSMApproval AS appsf
							WHERE 
								ApproveRoundGUID = @OldActualApproveRoundGuid 
								AND appsf.TableID = @ID
								AND appsf.FormIdent = @FormIdent 
								AND appsf.State != @DeletedState
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" Value="{{FormIdent}}" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="OldActualApproveRoundGuid" AlterIdent="ActualApproveRoundGuid" DataType="Guid" SetDataType="OldData"/>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsShowCategoryLevel5" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="String" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="String" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="String" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="String" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="String" />
						</Parameters>
					</DataSource>
				</Action>

			</Actions>
		</ActionShareCode><!-- <Action xsi:type="ShareCode" Ident="RejectActionShareCode" /> -->

    <ActionShareCode Ident="ApprovalInitActionShareCode">
			<Actions>

				<Action xsi:type="IF" ActionStart="AfterValidation">
					<Condition>
						<SQL>
							SELECT IIF(
								ISNULL(@IsFirstApproveGenerated, 0) != 1
								,1,0
							)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsFirstApproveGenerated" DataType="Number" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="GenerateSubForm" ControlIdent="ITSMApprovalRequestFakeSubForm" ActionStart="AfterValidation">
							<DataSource>
								<Columns>
									<Column Ident="ApproveOrder" DataBindType="Value" />
									<Column Ident="ApproverType" DataBindType="Value" />
									<Column Ident="ApproverGroupID" DataBindType="Value" />
									<Column Ident="ApproverAccountID" DataBindType="Value" />
									<Column Ident="ApproveRoundGUID" DataBindType="Value" />
								</Columns>
								<SQL><![CDATA[
									DECLARE @LastFolderTree VARCHAR(900);

									SET @LastFolderTree = COALESCE(
										CASE WHEN @IsShowCategoryLevel5 = 1 THEN NULLIF(@ITSMCategoryLevel5Ident, '') ELSE NULL END,
										NULLIF(@ITSMCategoryLevel4Ident, ''),
										NULLIF(@ITSMCategoryLevel3Ident, ''),
										NULLIF(@ITSMCategoryLevel2Ident, ''),
										NULLIF(@ITSMCompanyIdent, '')
									);

									SELECT
										(ISNULL(@LastApproveOrder,0) + appsf.ApproveOrder) AS ApproveOrder,
										appsf.ApproverType,
										appsf.ApproverGroupID,
										appsf.ApproverAccountID,
										@ActualApproveRoundGuid AS ApproveRoundGUID
									FROM usr.ITSMApproveSubForm AS appsf
									INNER JOIN usr.ITSMApproveSetting AS appSet ON appSet.ID = appsf.TableID AND appsf.FormIdent = @FormIdent AND appsf.State != @DeletedState
									INNER JOIN dbo.FolderTree AS folTre ON folTre.Ident = @LastFolderTree
									INNER JOIN dbo.Folder AS fol ON fol.ID = folTre.FolderID AND fol.FormIdent = @CategoryFormIdent
									INNER JOIN usr.ITSMCategory AS cat ON cat.ID = fol.TableID AND cat.ITSMApproveSettingID = appSet.ID
								]]></SQL>
								<Parameters>
									<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" Value="ITSMApproveSetting" />
									<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
									<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="CategoryFormIdent" DataType="String" Value="ITSMCategory" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsShowCategoryLevel5" DataType="Number" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="String" />
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="LastApproveOrder" DataType="Number" />
								</Parameters>
							</DataSource>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>
				<Action xsi:type="IF" ActionStart="AfterPermission">
					<Condition>
						<SQL>
							SELECT IIF(
								ISNULL(@IsFirstApproveGenerated, 0) != 1
								,1,0
							)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="IsFirstApproveGenerated" DataType="Number" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="ActionTrigger" Ident="FirstGenerated" ActionStart="AfterPermission">
							<DataSource>
								<SQL>

									UPDATE usr.{{FormIdent}}
									SET IsFirstApproveGenerated = 1
									WHERE ID = @ID

								</SQL>
								<Parameters>
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
								</Parameters>
							</DataSource>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

			</Actions>
		</ActionShareCode><!-- <Action xsi:type="ShareCode" Ident="RejectActionShareCode" /> -->

	</Section>
	
	<Section Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">
		<Action xsi:type="IF" ActionStart="AfterPermission">
			<Condition>
				<SQL>
					SELECT IIF(
						EXISTS(
							SELECT NULL
							FROM usr.ITSMApproval
							WHERE 
								ApproveRoundGUID = @ActualApproveRoundGuid
								AND ApproveRoundStartDateTime IS NULL
								AND State != 0
						)
						AND 
						EXISTS(
							SELECT NULL 
							FROM usr.{{FormIdent}}
							WHERE 
								ID = @ID
								AND State IN ({{TeamApproveState}},{{PersonApproveState}})
						)
						,1,0
					)
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
				</Parameters>
			</Condition>
			<TrueActions>
				<Action xsi:type="ActionTrigger" Ident="UpdateStartState" ActionStart="AfterPermission">
					<DataSource>
						<SQL><![CDATA[
								DECLARE @ITSMKey VARCHAR(100) = (
									SELECT ITSMKey
									FROM usr.{{FormIdent}}
									WHERE ID = @ID
								)
								DECLARE 
									@CounterIdent VARCHAR(100) = CONCAT(@ITSMKey, '_S'),
									@NextNumber INT

								EXEC @NextNumber = usr.CounterGetNext @CounterIdent, @UserID;

								UPDATE usr.ITSMApproval
								SET ApproveRoundStartDateTime = GETDATE(),ITSMKey = CONCAT(@ITSMKey, '_S:', @NextNumber)
								WHERE ApproveRoundGUID = @ActualApproveRoundGuid
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</DataSource>
				</Action>
			</TrueActions>
		</Action>
	</Section>
	
</Component>