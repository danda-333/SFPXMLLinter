	<Section Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">
		<Action xsi:type="IF" ActionStart="AfterPermission">
			<Condition>
				<SQL>
					SELECT IIF(
						EXISTS(
							SELECT NULL
							FROM usr.ITSMApproval
							WHERE 
								ApproveRoundGUID = @ActualApproveRoundGuid
								AND ApproveRoundStartDateTime IS NULL
								AND State != 0
						)
						,1,0
					)
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
				</Parameters>
			</Condition>
			<TrueActions>
				<Action xsi:type="ActionTrigger" Ident="UpdateStartState" ActionStart="AfterPermission">
					<DataSource>
						<SQL><![CDATA[
								DECLARE @ITSMKey VARCHAR(100) = (
									SELECT ITSMKey
									FROM usr.{{FormIdent}}
									WHERE ID = @ID
								)
								DECLARE 
									@CounterIdent VARCHAR(100) = CONCAT(@ITSMKey, '_S'),
									@NextNumber INT

								EXEC @NextNumber = usr.CounterGetNext @CounterIdent, @UserID;

								UPDATE usr.ITSMApproval
								SET ApproveRoundStartDateTime = GETDATE(),ITSMKey = CONCAT(@ITSMKey, '_S:', @NextNumber)
								WHERE ApproveRoundGUID = @ActualApproveRoundGuid
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</DataSource>
				</Action>
			</TrueActions>
		</Action>
	</Section>
	
