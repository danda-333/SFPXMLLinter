	<Section Root="Form" Name="Controls" TargetXPath="//Form/Controls" Insert="append">
		<Control xsi:type="SubFormControl" Ident="ITSMApprovalRequestFakeSubForm" TextResourceKey="ITSMApprovalRequestFakeSubForm_ITSM" FormIdent="ITSMApprovalRequestFakeSubForm" IsSortable="true" SortableControlIdent="ApproveOrder" InsertButtonIdent="SaveButton" DeleteButtonIdent="DeleteButton" UpdateButtonIdent="SaveButton" IsReadOnly="true" IsVisible="false">
			<DataSource>
				<Columns>
					<Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" IsVisible="false" />
					<Column xsi:type="SortableColumn" Ident="ApproveOrder" Width="10" IsDefaultSort="true" SortType="ASC"/>
					<Column xsi:type="ToolBarColumn" Ident="Approver" TitleResourceKey="Approver_ITSM" Width="80" IsClickable="true">
						<HTMLTemplate><![CDATA[
							[IF('Group'=='[%ApproverTypeValue%]')]
								[%ApproverGroupID%]
							[/IF]
							[IF('Account'=='[%ApproverTypeValue%]')]
								[%ApproverAccountID%]
							[/IF]
						]]></HTMLTemplate>
					</Column>
					<Column xsi:type="DeleteColumn" Ident="ID" Width="10"/>

					<Column Ident="ApproverTypeValue" IsVisible="false"/>
					<Column Ident="ApproverGroupID" IsVisible="false"/>
					<Column Ident="ApproverAccountID" IsVisible="false"/>
				</Columns>
				<SQL><![CDATA[
					SELECT
						itsApp.ID
						,itsApp.ApproveOrder
						,itsApp.ApproverType AS ApproverTypeValue
						,approverGro.[Name] AS ApproverGroupID
						,approverAcc.FullName AS ApproverAccountID
					FROM usr.ITSMApproval AS itsApp
					LEFT JOIN dbo.[Group] AS approverGro on approverGro.ID = itsApp.ApproverGroupID
					LEFT JOIN dbo.[Account] AS approverAcc on approverAcc.ID = itsApp.ApproverAccountID
					WHERE
						itsApp.TableID = @ID
						AND itsApp.FormIdent = @ThisFormIdent
						AND itsApp.[State] != @DeletedState
						AND itsApp.ApproveRoundGUID = @ActualApproveRoundGuid
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
				</Parameters>
			</DataSource>
		</Control>
		<Control xsi:type="PlaceHolderControl" Ident="ApproverSubFormCardPlaceHolder" IsVisible="false"/>
		<Control xsi:type="TextBoxControl" Ident="IsFirstApproveGenerated" DataType="Number" Default="0"/>
		<Control xsi:type="TextBoxControl" Ident="ActualApproveRoundGuid" DataType="Guid" Default="NEWID()"/>
		<Control xsi:type="TextBoxControl" Ident="LastApproveOrder" DataType="Number" >
			<DataBind>
				<Dependencies>
					<string>ITSMApprovalRequestFakeSubForm</string>
				</Dependencies>
				<Columns>
					<Column Ident="ApproveOrder" DataBindType="Value"/>
				</Columns>
				<SQL><![CDATA[
					SELECT MAX(ApproveOrder) AS ApproveOrder
					FROM @ITSMApprovalRequestFakeSubForm
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:TableParameter" Ident="ITSMApprovalRequestFakeSubForm"/>
				</Parameters>
			</DataBind>
		</Control>

		<Control xsi:type="PlaceHolderControl" Ident="PHMultiApprove" IsVisible="false"/>

		<Control xsi:type="HTMLContentViewControl" Ident="ApproveHistory" IsRazorEngine="true">
			<Sources>
				<DataSource Ident="ApproveInfo">
					<Columns>
						<Column Ident="ApproverName" />
						<Column Ident="ITSMKey" />
						<Column Ident="ApprovedName" />
						<Column Ident="IsApproved" IsTranslate="true"/>
						<Column Ident="TrCssClass" />
						<Column Ident="ApproveDateTime" />
						<Column Ident="ApproveComment" />
					</Columns>
					<SQL>
						SELECT
							CASE itsApp.ApproverType
								WHEN 'Account' THEN approverAcc.FullName
								WHEN 'Group' THEN approverGro.[Name]
							END AS ApproverName,
							ITSMKey,
							approvedAcc.FullName AS ApprovedName,
							CASE 
								WHEN itsApp.IsApproved = 0 THEN 'NotApproved_ITSM'
								WHEN itsApp.IsApproved = 1 THEN 'Approved_ITSM'
								WHEN EXISTS(
									SELECT NULL 
									FROM usr.ITSMApprovalEscalation AS itsmAppEsc
									WHERE itsmAppEsc.ITSMApprovalID = itsApp.ID
								) THEN 'ApprovalEscalated_ITSM'
								ELSE 'WithoutReaction_ITSM'
							END AS IsApproved,
							CASE 
								WHEN itsApp.IsApproved = 0 THEN 'bg-danger-lmtl4 bg-opacity-25-lmtl4 text-dark-lmtl4'
								WHEN itsApp.IsApproved = 1 THEN 'bg-success-lmtl4 bg-opacity-25-lmtl4 text-dark-lmtl4'
								WHEN EXISTS(
									SELECT NULL 
									FROM usr.ITSMApprovalEscalation AS itsmAppEsc
									WHERE itsmAppEsc.ITSMApprovalID = itsApp.ID
								) THEN 'bg-warning-lmtl4 bg-opacity-25-lmtl4 text-dark-lmtl4'
								ELSE ''
							END AS TrCssClass,
							itsApp.ApproveDateTime,
							itsApp.ApproveComment
						FROM usr.ITSMApproval AS itsApp
						LEFT JOIN dbo.[Group] AS approverGro on approverGro.ID = itsApp.ApproverGroupID
						LEFT JOIN dbo.[Account] AS approverAcc on approverAcc.ID = itsApp.ApproverAccountID
						LEFT JOIN dbo.[Account] AS approvedAcc ON approvedAcc.ID = itsApp.ApprovedAccountID
						WHERE
							itsApp.TableID = @ID
							AND itsApp.FormIdent = @ThisFormIdent
							AND itsApp.[State] != @DeletedState
							AND ApproveRoundStartDateTime IS NOT NULL
						ORDER BY ApproveRoundStartDateTime ASC, ApproveOrder ASC
					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
					</Parameters>
				</DataSource>
				<DataSource Ident="ITSMKeyGroup">
					<Columns>
						<Column Ident="ITSMKey" />
					</Columns>
					<SQL>
						SELECT
							ITSMKey
						FROM (
							SELECT
								CASE itsApp.ApproverType
									WHEN 'Account' THEN approverAcc.FullName
									WHEN 'Group' THEN approverGro.[Name]
								END AS ApproverName,
								ITSMKey,
								approvedAcc.FullName AS ApprovedName,
								CASE itsApp.IsApproved
									WHEN 0 THEN 'NotApproved_ITSM'
									WHEN 1 THEN 'Approved_ITSM'
									ELSE 'WithoutReaction_ITSM'
								END AS IsApproved,
								itsApp.ApproveDateTime,
								itsApp.ApproveComment,
								itsApp.ApproveRoundStartDateTime,
								itsApp.ApproveOrder,
								ROW_NUMBER() OVER (PARTITION BY ITSMKey ORDER BY ApproveRoundStartDateTime ASC, ApproveOrder ASC) AS rn
							FROM usr.ITSMApproval AS itsApp
							LEFT JOIN dbo.[Group] AS approverGro ON approverGro.ID = itsApp.ApproverGroupID
							LEFT JOIN dbo.[Account] AS approverAcc ON approverAcc.ID = itsApp.ApproverAccountID
							LEFT JOIN dbo.[Account] AS approvedAcc ON approvedAcc.ID = itsApp.ApprovedAccountID
							WHERE
								itsApp.TableID = @ID
								AND itsApp.FormIdent = @ThisFormIdent
								AND itsApp.[State] != @DeletedState
								AND ApproveRoundStartDateTime IS NOT NULL
						) AS sub
						WHERE rn = 1
						ORDER BY ApproveRoundStartDateTime DESC, ApproveOrder ASC
					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
					</Parameters>
				</DataSource>
			</Sources>
			<HTMLTemplate>

				<style>
					.image-within-max-width-100 img {
						max-width: 100%;
					}
				</style>

				@foreach(var group in Model.Data.ITSMKeyGroup) {
					<div class="card-lmtl4">
						<div class="card-header-lmtl4">
							<h5 class="mb-0-lmtl4">@group.ITSMKey</h5>
						</div>

						<div class="table-responsive-lmtl4">
							<table class="table-lmtl4">
								<thead>
									<tr>
										<th>[#ApproverName_ITSM#]</th>
										<th>[#ApprovedName_ITSM#]</th>
										<th>[#IsApproved_ITSM#]</th>
										<th>[#ApproveDateTime_ITSM#]</th>
										<th>[#ApproveComment_ITSM#]</th>
									</tr>
								</thead>
								<tbody>
									@foreach(var item in Model.Data.ApproveInfo)
									{
										if(item.ITSMKey == group.ITSMKey){
											<tr class="@item.TrCssClass">
												<td>@item.ApproverName</td>
												<td>@item.ApprovedName</td>
												<td class="@item.IsApproved">@item.IsApproved</td>
												<td>@item.ApproveDateTime</td>
												<td class="image-within-max-width-100">@Html.Raw(item.ApproveComment)</td>
											</tr>
										}
									}
								</tbody>
							</table>
						</div>
					</div>
				}

			</HTMLTemplate>
		</Control>

		<Control xsi:type="HTMLContentViewControl" Ident="CurrentApprovalListContentView" IsRazorEngine="true">
			<Sources>
				<DataSource Ident="CurrentApprovalList">
					<Columns>
						<Column Ident="RowNum" />
						<Column Ident="ApproverTypeValue" IsTranslate="true"/>
						<Column Ident="ApproverType" />
						<Column Ident="ApproverGroupID" />
						<Column Ident="ApproverAccountID" />
					</Columns>
					<SQL><![CDATA[

						SELECT
							ROW_NUMBER() OVER (ORDER BY itsApp.ApproveOrder ASC) AS RowNum
							,CONCAT(itsApp.ApproverType, '_ITSM') AS ApproverTypeValue
							,itsApp.ApproverType
							,approverGro.[Name] AS ApproverGroupID
							,approverAcc.FullName AS ApproverAccountID
						FROM @ITSMApprovalRequestFakeSubForm AS itsApp
						LEFT JOIN dbo.[Group] AS approverGro on approverGro.ID = itsApp.ApproverGroupID
						LEFT JOIN dbo.[Account] AS approverAcc on approverAcc.ID = itsApp.ApproverAccountID
						ORDER BY itsApp.ApproveOrder ASC

					]]></SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualApproveRoundGuid" DataType="Guid" />
						<dsp:Parameter xsi:type="dsp:TableParameter" Ident="ITSMApprovalRequestFakeSubForm" />
					</Parameters>
				</DataSource>
			</Sources>
			<HTMLTemplate>
				<table class="table">
					<thead>
						<tr>
							<th>[#ApproveOrder_ITSM#]</th>
							<th>[#ApproverType_ITSM#]</th>
							<th>[#Approver_ITSM#]</th>
						</tr>
					</thead>
					<tbody>
						@foreach(var item in Model.Data.CurrentApprovalList)
						{
							<tr>
								<td>@item.RowNum</td>
								<td>@item.ApproverTypeValue</td>
								<td>
									@if(item.ApproverType == "Group"){
										@item.ApproverGroupID
									} else if (item.ApproverType == "Account"){
										@item.ApproverAccountID
									}
								</td>
							</tr>
						}
					</tbody>
				</table>
			</HTMLTemplate>
		</Control>
	</Section>

