	<Section Root="WorkFlow" Name="ActionShareCodes" TargetXPath="//WorkFlow/ActionShareCodes" Insert="append">

		<ActionShareCode Ident="ApproveActionShareCode">
			<Actions>
				<Action xsi:type="IF" ActionStart="BeforeValidation">
					<Condition>
						<SQL>
							SELECT IIF( 
								ISNULL(@Communication, '') = ''
								AND NOT EXISTS(
									SELECT NULL
									FROM usr.{{FormIdent}} AS tic
									OUTER APPLY (
										SELECT TOP(1) his.*
										FROM dbo.History AS his
										WHERE  
											his.TableID = tic.ID
											AND his.FormIdent = '{{FormIdent}}'
											AND his.HistoryTypeID = 'ChangeState'
										ORDER BY his.CreateDate DESC
									) AS hisLast
									INNER JOIN dbo.Communication AS com 
										ON com.TableID = tic.ID
										AND com.FormIdent = '{{FormIdent}}'
										AND com.CreateDate >= ISNULL(hisLast.CreateDate, tic.CreateDate)
										AND com.AccountID = @UserID
										AND com.CommunicationTypeID = 'Comment_ITSM'
									WHERE tic.ID = @ID
								)
							, 1, 0)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Communication" SetDataType="ActualData" DataType="String"  />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="Required" ActionStart="BeforeValidation">
							<Idents>
								<string>DialogCommunication</string>
							</Idents>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

				<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterSave">
					<DataSource>
						<SQL>

							UPDATE usr.ITSMAssessment
							SET IsApproved = @ApprovedState
							, ApproveDateTime = GETDATE()
							, ApprovedAccountID = @UserID
							, AssessmentComment = @DialogCommunication
							WHERE 
								TableID = @ID
								AND FormIdent = @FormIdent
								AND AssessmentRoundGUID = @ActualAssessmentRoundGuid
								AND AssessmentOrder = (
									SELECT MIN(sub.AssessmentOrder)
									FROM usr.ITSMAssessment sub
									WHERE sub.FormIdent = @FormIdent
										AND sub.TableID = @ID
										AND sub.AssessmentRoundGUID = @ActualAssessmentRoundGuid
										AND sub.State != 0
										AND sub.IsApproved IS NULL
								)
								AND IsApproved IS NULL
								AND State != 0

						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="State" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ApprovedState" DataType="Number" Value="1"/>
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualAssessmentRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="DialogCommunication" DataType="String" />
						</Parameters>
					</DataSource>
				</Action>

        <!-- <Action xsi:type="History" Ident="HistoryActionApproved" HistoryType="Approve_ITSM" ActionStart="AfterSave"/> -->

				<Action xsi:type="IF" ActionStart="AfterPermission">
					<Condition>
						<SQL>
							SELECT IIF(
								NOT EXISTS(
									SELECT NULL
									FROM usr.ITSMAssessment
									WHERE 
										TableID = @ID
										AND FormIdent = @FormIdent
										AND AssessmentRoundGUID = @ActualAssessmentRoundGuid
										AND IsApproved IS NULL
										AND State != 0
								)
								,1,0
							)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="State" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualAssessmentRoundGuid" DataType="Guid" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterPermission">
							<DataSource>
								<SQL>

									UPDATE usr.{{FormIdent}}
									SET ActualAssessmentRoundGuid = NEWID()
									WHERE ID = @ID

								</SQL>
								<Parameters>
									<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
								</Parameters>
							</DataSource>
						</Action>
						<Action xsi:type="ChangeState" State="80" ActionStart="AfterSave" />
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

			</Actions>

		</ActionShareCode><!-- <Action xsi:type="ShareCode" Ident="ApproveActionShareCode" /> -->

    <ActionShareCode Ident="RejectActionShareCode">
			<Actions>
				<Action xsi:type="IF" ActionStart="BeforeValidation">
					<Condition>
						<SQL>
							SELECT IIF( 
								ISNULL(@Communication, '') = ''
								AND NOT EXISTS(
									SELECT NULL
									FROM usr.{{FormIdent}} AS tic
									OUTER APPLY (
										SELECT TOP(1) his.*
										FROM dbo.History AS his
										WHERE  
											his.TableID = tic.ID
											AND his.FormIdent = '{{FormIdent}}'
											AND his.HistoryTypeID = 'ChangeState'
										ORDER BY his.CreateDate DESC
									) AS hisLast
									INNER JOIN dbo.Communication AS com 
										ON com.TableID = tic.ID
										AND com.FormIdent = '{{FormIdent}}'
										AND com.CreateDate >= ISNULL(hisLast.CreateDate, tic.CreateDate)
										AND com.AccountID = @UserID
										AND com.CommunicationTypeID = 'Comment_ITSM'
									WHERE tic.ID = @ID
								)
							, 1, 0)
						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Communication" SetDataType="ActualData" DataType="String"  />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</Condition>
					<TrueActions>
						<Action xsi:type="Required" ActionStart="BeforeValidation">
							<Idents>
								<string>DialogCommunication</string>
							</Idents>
						</Action>
					</TrueActions>
					<FalseActions>
					</FalseActions>
				</Action>

				<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterSave">
					<DataSource>
						<SQL>

							UPDATE usr.ITSMAssessment
							SET IsApproved = @ApprovedState
							, ApproveDateTime = GETDATE()
							, ApprovedAccountID = @UserID
							, AssessmentComment = @DialogCommunication
							WHERE 
								TableID = @ID
								AND FormIdent = @FormIdent
								AND AssessmentRoundGUID = @ActualAssessmentRoundGuid
								AND AssessmentOrder = (
									SELECT MIN(sub.AssessmentOrder)
									FROM usr.ITSMAssessment sub
									WHERE sub.FormIdent = @FormIdent
										AND sub.TableID = @ID
										AND sub.AssessmentRoundGUID = @ActualAssessmentRoundGuid
										AND sub.State != 0
										AND sub.IsApproved IS NULL
								)
								AND IsApproved IS NULL
								AND State != 0

						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="State" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ApprovedState" DataType="Number" Value="0"/>
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="{{FormIdent}}"/>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualAssessmentRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="DialogCommunication" DataType="String" />
						</Parameters>
					</DataSource>
				</Action>

				<Action xsi:type="ActionTrigger" Ident="SetApproved" ActionStart="AfterPermission">
					<DataSource>
						<SQL>

							UPDATE usr.{{FormIdent}}
							SET ActualAssessmentRoundGuid = NEWID()
							WHERE ID = @ID

						</SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
						</Parameters>
					</DataSource>
				</Action>

        <Action xsi:type="ChangeState" State="70" ActionStart="AfterSave" />
			</Actions>
		</ActionShareCode><!-- <Action xsi:type="ShareCode" Ident="RejectActionShareCode" /> -->

	</Section>
	
	<Section Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">
		<Action xsi:type="IF" ActionStart="AfterPermission">
			<Condition>
				<SQL>
					SELECT IIF(
						EXISTS(
							SELECT NULL
							FROM usr.ITSMAssessment
							WHERE 
								AssessmentRoundGUID = @ActualAssessmentRoundGuid
								AND AssessmentRoundStartDateTime IS NULL
								AND State != 0
						)
						AND 
						EXISTS(
							SELECT NULL 
							FROM usr.{{FormIdent}}
							WHERE 
								ID = @ID
								AND State = ({{AssessmentState}})
						)
						,1,0
					)
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualAssessmentRoundGuid" DataType="Guid" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
				</Parameters>
			</Condition>
			<TrueActions>
				<Action xsi:type="ActionTrigger" Ident="UpdateStartState" ActionStart="AfterPermission">
					<DataSource>
						<SQL><![CDATA[
								DECLARE @ITSMKey VARCHAR(100) = (
									SELECT ITSMKey
									FROM usr.{{FormIdent}}
									WHERE ID = @ID
								)
								DECLARE 
									@CounterIdent VARCHAR(100) = CONCAT(@ITSMKey, '_P'),
									@NextNumber INT

								EXEC @NextNumber = usr.CounterGetNext @CounterIdent, @UserID;

								UPDATE usr.ITSMAssessment
								SET AssessmentRoundStartDateTime = GETDATE(),ITSMKey = CONCAT(@ITSMKey, '_P:', @NextNumber)
								WHERE AssessmentRoundGUID = @ActualAssessmentRoundGuid
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ActualAssessmentRoundGuid" DataType="Guid" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</DataSource>
				</Action>
			</TrueActions>
		</Action>
	</Section>
	
</Component>