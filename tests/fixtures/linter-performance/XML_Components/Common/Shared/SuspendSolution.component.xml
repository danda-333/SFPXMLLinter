	<Section Root="Form" Name="Controls" TargetXPath="//Form/Controls" Insert="append">
		<Control xsi:type="DropDownListControl" Ident="ITSMSolutionSuspendReasonGuid" DataType="Guid" TitleResourceKey="ITSMSolutionSuspendReasonGuid_ITSM" IsFakeReadOnly="true">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM" DefaultValue="">
				<Columns>
					<Column Ident="Guid" DataBindType="Value" />
					<Column Ident="TextValue" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						dialsetting.Guid,
						dial.TextValue
					FROM usr.ITSMSolutionSuspendReason AS dial
					INNER JOIN usr.ITSMSolutionSuspendReasonSetting AS dialsetting 
						ON dialsetting.Guid = dial.Guid
					WHERE 
						dial.LanguageID = @UserLanguageID
						AND dial.[State] != @DeletedState
					ORDER BY dial.OrderValue ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
				</Parameters>
			</DataBind>
			<TimeLineDataBind TransformType="AutoQuery" DatabaseScheme="usr" FormIdent="ITSMSolutionSuspendReason" KeyColumnIdent="Guid" KeyColumnDataType="UNIQUEIDENTIFIER" TitleColumnIdent="TextValue" TitleColumnDataType="VARCHAR(255)" LanguageIDColumnIdent="LanguageID"/>
		</Control>
		<Control xsi:type="DropDownListControl" Ident="DialogITSMSolutionSuspendReasonGuid" DataType="Guid" TitleResourceKey="DialogITSMSolutionSuspendReasonGuid_ITSM" IsShowRequired="true">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM" DefaultValue="">
				<Columns>
					<Column Ident="Guid" DataBindType="Value" />
					<Column Ident="TextValue" DataBindType="Title" />
					<Column Ident="Selected" DataBindType="Selected" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						dialsetting.Guid
						,dial.TextValue
						,IIF(dialsetting.Guid = @ITSMSolutionSuspendReasonGuid, 1, 0) AS Selected
					FROM usr.ITSMSolutionSuspendReason AS dial
					INNER JOIN usr.ITSMSolutionSuspendReasonSetting AS dialsetting 
						ON dialsetting.Guid = dial.Guid
					WHERE 
						dial.LanguageID = @UserLanguageID
						AND dial.[State] != @DeletedState
					ORDER BY dial.OrderValue ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMSolutionSuspendReasonGuid" DataType="Guid"/>
				</Parameters>
			</DataBind>
		</Control>
	</Section>

	<Section Root="DataView" Name="Columns" Insert="placeholder">
		<Column Ident="ITSMSolutionSuspendReasonGuid" TitleResourceKey="ITSMSolutionSuspendReasonGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
			<SQL><![CDATA[
				solSusRea.[TextValue] AS ITSMSolutionSuspendReasonGuid
			]]></SQL>
		</Column>
	</Section>
	<Section Root="DataView" Name="Froms" TargetXPath="//DataView/DataSource/Froms | //DataView/Sections/Section[@Ident='BasicExportSection']/DataSource/Froms" AllowMultipleInserts="true" Insert="append">
		<dsf:From Ident="solSusRea">
			<dsf:Columns>
				<dsf:string>ITSMSolutionSuspendReasonGuid</dsf:string>
			</dsf:Columns>
			<dsf:SQL>
				LEFT JOIN usr.ITSMSolutionSuspendReason as solSusRea on solSusRea.Guid = itsm.ITSMSolutionSuspendReasonGuid AND solSusRea.LanguageID = @UserLanguageID
			</dsf:SQL>
		</dsf:From>
	</Section>

