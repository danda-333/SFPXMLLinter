						</Parameters>
					</DataSource>
				</Action>
				<Action xsi:type="SetValue" Ident="DialogITSMSolutionSuspendReasonGuid" Value="" ActionStart="AfterValidation" />

			</Actions>
		</ActionShareCode> <!-- <Action xsi:type="ShareCode" Ident="SuspendSolution_Update_FromDialog_ActionShare" /> -->
		
	</Section>

	<Section Root="WorkFlow" Name="GlobalActions" TargetXPath="//WorkFlow/GlobalActions" Insert="append">

		<Action xsi:type="IF" ActionStart="AfterValidation">
			<Condition>
				<SQL>
					SELECT IIF(
						ISNULL(@Var_ButtonIdent, '') NOT IN ('SuspendSolutionButton','InternallySuspendSolutionButton')
						,1,0
					)
				</SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="Var_ButtonIdent" DataType="String" MaxLength="255"/>
				</Parameters>
			</Condition>
			<TrueActions>
				<Action xsi:type="SetValue" Ident="ITSMSolutionSuspendReasonGuid" Value="" ActionStart="AfterValidation" />
			</TrueActions>
		</Action>
		
	</Section>

</Component>