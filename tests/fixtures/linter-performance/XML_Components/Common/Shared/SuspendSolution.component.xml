	<Section Root="WorkFlow" Name="ActionShareCodes" TargetXPath="//WorkFlow/ActionShareCodes" Insert="append">
		
		<ActionShareCode Ident="SuspendSolution_Update_FromDialog_ActionShare">
			<Actions>

				<Action xsi:type="Required" ActionStart="BeforeValidation">
          <Idents>
            <string>DialogITSMSolutionSuspendReasonGuid</string>
          </Idents>
        </Action>

				<Action xsi:type="ActionValue" Ident="SolutionSuspendReasonGuid_Update_FromDialog_Action" ControlIdent="ITSMSolutionSuspendReasonGuid" ActionStart="AfterValidation">
					<DataSource>
						<SQL><![CDATA[
							SELECT @DialogITSMSolutionSuspendReasonGuid
						]]></SQL>
						<Parameters>
