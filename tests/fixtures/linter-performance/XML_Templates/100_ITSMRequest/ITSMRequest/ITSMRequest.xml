		<Section xsi:type="GlobalChangeSection" Ident="SuspendSolutionGlobalChangeSection">
			<ValidationBeforeOpen ErrorMessageResourceKey="SuspendSolutionGlobalChangeSection_Error_ITSM">
				<Condition>
					<SQL>
						
						SELECT 1 AS ID
						WHERE
							(
								SELECT COUNT(itsReq.ID)
								FROM @SelectedIDs AS selIDs
								INNER JOIN usr.ITSMRequest AS itsReq ON itsReq.ID = selIDs.ID
								WHERE itsReq.[State] NOT IN (
									@SolutionAssignedToTeamState
									,@SolutionAssignedState
									,@SolutionInternallySuspendedState
									,@SolutionSuspendedForReviewState
								)
							) > 0

					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionAssignedToTeamState" DataType="Number" Value="110" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionAssignedState" DataType="Number" Value="120" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionInternallySuspendedState" DataType="Number" Value="130" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionSuspendedForReviewState" DataType="Number" Value="140" />

					</Parameters>
				</Condition>
			</ValidationBeforeOpen>
			<Controls>
				<wffc:FormControl Ident="DialogITSMSolutionSuspendReasonGuid" IsRequired="true" IsVisible="true" IsReadOnly="false" />
				<wffc:FormControl Ident="DialogCommunication" IsRequired="true" IsVisible="true" IsReadOnly="false" />
			</Controls>
			<Controls>
