					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedForReviewState" DataType="Number" Value="155" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedState" DataType="Number" Value="160" />

					</Parameters>
				</Condition>
			</ValidationBeforeOpen>
