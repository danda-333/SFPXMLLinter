		<Control xsi:type="FormDialogControl" Ident="ITSMRequestBreakdownFormDialogOpen" CreateButtonTitleResourceKey="AddITSMRequestBreakdownButton_ITSM" FormIdent="ITSMRequestBreakdownFormDialog" IsReadOnly="true">
			<Actions>
				<Action xsi:type="GenerateSubForm" ControlIdent="ITSMRequestBreakdownSubForm" ActionStart="BeforeValidation" >
					<DataSource>
						<Columns>
							<Column Ident="BreakdownFolderTreeIdent" DataBindType="Value"/>
							<Column Ident="BreakdownFolderTreeIdentName" DataBindType="Title" ParentColumnIdent="BreakdownFolderTreeIdent"/>
						</Columns>
						<SQL><![CDATA[
							SELECT
								ft.Ident AS BreakdownFolderTreeIdent
								,STUFF(
									(
										SELECT ' → ' + ftv.FolderName
										FROM (
											SELECT TOP (LEN(ft.Ident) / 7)
											ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n
											FROM sys.objects
										) x
										INNER JOIN dbo.FolderTreeView as ftv on ftv.Ident = LEFT(ft.Ident,(7*n))
										

										FOR XML PATH('')
								), 1, 3, '') AS BreakdownFolderTreeIdentName
							FROM dbo.FolderTree as ft
							INNER JOIN dbo.Folder as f on f.ID = ft.FolderID AND f.[State] = @StateOne 
							WHERE
								ft.[Ident] IN (SELECT ID FROM @BreakdownFolderTreeIdent)
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="BreakdownFolderTreeIdent" DataType="VarCharList"/>
							<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="StateOne" DataType="Number" Value="1"/>
						</Parameters>
					</DataSource>
				</Action>
			</Actions>
		</Control>

		<Control xsi:type="SubFormControl" Ident="ITSMRequestBreakdownSubForm" TextResourceKey="ITSMRequestBreakdownSubForm_ITSM" FormIdent="ITSMRequestBreakdownSubForm" IsSortable="true" SortableControlIdent="ApproveOrder" InsertButtonIdent="SaveButton" DeleteButtonIdent="DeleteButton" UpdateButtonIdent="SaveButton" IsReadOnly="true">
			<DataSource>
				<Columns>
					<Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" IsVisible="false" />
					<Column Ident="BreakdownFolderTreeIdent" TitleResourceKey="BreakdownFolderTreeIdent_ITSM" Width="70" />
					<Column xsi:type="DeleteColumn" Ident="ID" Width="10"/>
				</Columns>
				<SQL><![CDATA[
					SELECT
						itsmSupConSF.ID
						,STUFF(
							(
								SELECT ' → ' + ftv.FolderName
								FROM (
									SELECT TOP (LEN(itsmSupConSF.BreakdownFolderTreeIdent) / 7)
									ROW_NUMBER() OVER (ORDER BY (SELECT NULL)) AS n
									FROM sys.objects
								) x
								INNER JOIN dbo.FolderTreeView as ftv on ftv.Ident = LEFT(itsmSupConSF.BreakdownFolderTreeIdent,(7*n))
								

								FOR XML PATH('')
						), 1, 3, '') AS BreakdownFolderTreeIdent
					FROM usr.ITSMRequestBreakdownSubForm as itsmSupConSF
					WHERE
						itsmSupConSF.TableID = @ID
						AND itsmSupConSF.FormIdent = @ThisFormIdent
						AND itsmSupConSF.[State] != @DeletedState
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" Value="0" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ThisFormIdent" DataType="String" MaxLength="50" Value="ITSMRequest"/>
				</Parameters>
			</DataSource>
		</Control>

		<Control xsi:type="TextBoxControl" Ident="IsShowITSMRequestBreakdown" DataType="Number" TitleResourceKey="IsShowITSMRequestBreakdown_ITSM" IsCreateColumn="false" IsFakeReadOnly="true" IsServerDataHackValidation="true">
			<DataBind>
				<Dependencies>
					<string>ITSMCategoryLevel3Ident</string>
				</Dependencies>
				<Columns>
					<Column Ident="IsShowITSMRequestBreakdown" DataBindType="Value"/>
				</Columns>
				<SQL><![CDATA[
					DECLARE @LastTreeIdent VARCHAR(900)	=	(SELECT COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent))

					SELECT
						IIF(
							EXISTS(
								SELECT NULL
								FROM usr.ITSMCategory AS cat
								INNER JOIN dbo.FolderTreeView AS folTre ON folTre.TableID = cat.ID AND folTre.FormIdent = @FormIdent
								WHERE folTre.Ident = @LastTreeIdent AND ISNULL(cat.IsBreakdown,0) = 1 AND cat.State != @DeletedState
							)
							, 1
							, 0
						) AS IsShowITSMRequestBreakdown
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" Value="ITSMCategory" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="String" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="String" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="String" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="String" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="String" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
				</Parameters>
			</DataBind>
		</Control>

