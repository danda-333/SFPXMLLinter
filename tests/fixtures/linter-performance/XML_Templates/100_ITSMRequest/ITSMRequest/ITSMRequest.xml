		<Section xsi:type="GlobalChangeSection" Ident="CloseGlobalChangeSection" ConfirmButtonTitleResourceKey="ConfirmGlobalChangeButton_ITSM">
			<ValidationBeforeOpen ErrorMessageResourceKey="CloseGlobalChangeSection_Error_ITSM">
