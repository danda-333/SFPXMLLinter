		<Control xsi:type="TextBoxControl" Ident="ITSMSupplierRequestClassificationTypeFunctionalKey" DataType="String" TitleResourceKey="ITSMSupplierRequestClassificationTypeFunctionalKey_ITSM" IsCreateColumn="false" IsFakeReadOnly="true">
