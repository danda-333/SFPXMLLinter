<?xml version="1.0" encoding="utf-8"?>
<DataView xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:dsf="http://www.gappex.com/sfp/DataSource/Froms" xmlns:dws="http://www.gappex.com/sfp/DataView/Settings" Ident="ITSMSupplierRequestStateCloneView" SegmentType="ITSMSupplierRequestSegment" Priority="200" TitleResourceKey="ITSMSupplierRequestStateCloneView_ITSM" GroupTitleResourceKey="ITSMSupplierRequestStateGroup_ITSM" PackageIdent="ITSMPackage" IsManualPaging="true" IsGeneratePaging="false" DefaultFilterIdent="ITSMSupplierRequestFilter" ShareFilterIdent="ITSMSupplierRequestFilter">
	<Usings>
		<Using Component="Common/Shared/BaseView"/>
		<Using Component="Common/Shared/FolderGroupSegment" FormIdent="ITSMSupplierRequest"/>
		<Using Component="Common/Shared/Resolve"/>

		<Using Component="Common/Controls/ReporterControls"/>
  </Usings>
  <AccessPermissions>
		<string>ITSMSupplierRequest</string>
	</AccessPermissions>

  <Settings>
    <dws:Setting xsi:type="dws:CloneDataViewSetting">
      <dws:DataSource>
        <dws:SQL>
          SELECT
            CONCAT('ITSMSupplierRequest',REPLACE(TitleResourceKey,'_ITSM','View')) AS Ident
            , CONCAT('ITSMSupplierRequest_',REPLACE(TitleResourceKey,'_ITSM','View'),'_ITSM') AS TitleResourceKey
            , [Value] AS StateValue
            , 200 + [Value] AS Priority
            , ColorCssClass AS CountColorCssClass
          FROM usr.ITSMGetWorkFlowState('ITSMSupplierRequestWorkFlow')
          WHERE
            [Value] NOT IN (@DeletedState,@NewState)
        </dws:SQL>
        <dws:Parameters>
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="NewState" DataType="Number" Value="1" />
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
        </dws:Parameters>
      </dws:DataSource>
    </dws:Setting>
  </Settings>

  <Buttons>
	</Buttons>
  <DataSource FormIdent="ITSMSupplierRequest">
    <DataPermissions>
      <string>ITSMSupplierRequestReporter</string>

      <string>ITSMOperator</string>
      <string>ITSMSupplier</string>
    </DataPermissions>
		<Columns>
      <Include Component="Common/Shared/BaseView" Section="Columns"/>
      <Include Component="Common/Shared/ITSMKey" Section="Columns"/>
      <Column Ident="Subject" TitleResourceKey="Subject_ITSM" Width="20" TableAlterIdent="tbl">
        <SQL><![CDATA[
          itsm.[Subject]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/FolderGroupSegment" Section="Columns"/>
      <Include Component="Common/Shared/BaseView" Section="WorkFlowStateColumn" FormIdent="ITSMSupplierRequest"/>
      <Include Component="Common/Controls/ReporterControls" Section="Columns"/>
      <Column Ident="Description" TitleResourceKey="Description_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[Description]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/Resolve" Section="Columns"/>
      <Column Ident="ITSMSupplierRequestClassificationTypeGuid" TitleResourceKey="ITSMSupplierRequestClassificationTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsSupReqClaTyp.[TextValue] AS ITSMSupplierRequestClassificationTypeGuid
        ]]></SQL>
      </Column>
      <Column Ident="ITSMIncidentClassificationTypeGuid" TitleResourceKey="ITSMIncidentClassificationTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsIncClaTyp.[TextValue] AS ITSMIncidentClassificationTypeGuid
        ]]></SQL>
      </Column>
      <Column Ident="ITSMOperationalEnvironmentTypeGuid" TitleResourceKey="ITSMOperationalEnvironmentTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsOpeEnvTyp.[TextValue] AS ITSMOperationalEnvironmentTypeGuid
        ]]></SQL>
      </Column>
		</Columns>
    <Froms>
      <dsf:From Ident="itsSupReqClaTyp">
        <dsf:Columns>
          <dsf:string>ITSMSupplierRequestClassificationTypeGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMSupplierRequestClassificationType AS itsSupReqClaTyp ON itsSupReqClaTyp.Guid = itsm.ITSMSupplierRequestClassificationTypeGuid AND itsSupReqClaTyp.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="itsIncClaTyp">
        <dsf:Columns>
          <dsf:string>ITSMIncidentClassificationTypeGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMIncidentClassificationType AS itsIncClaTyp ON itsIncClaTyp.Guid = itsm.ITSMIncidentClassificationTypeGuid AND itsIncClaTyp.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="itsOpeEnvTyp">
        <dsf:Columns>
          <dsf:string>ITSMOperationalEnvironmentTypeGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMOperationalEnvironmentType AS itsOpeEnvTyp ON itsOpeEnvTyp.Guid = itsm.ITSMOperationalEnvironmentTypeGuid AND itsOpeEnvTyp.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
    </Froms>
		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMSupplierRequest AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] != @DeletedState
            AND (
              (
                ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter|]#
              )
              OR
              (
                ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter,ITSMAuthor|]#
              )
              OR
              (
                #PERMISSION[ITSMSupplierRequest(itsm)]#
              )
            ) #FILTER# #DYNAMICWHERE#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" /> 
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StateValue" ConstantType="LocalVariable" DataType="Number" >
        <dsp:FilterConditions>
          <dsp:DataSource>
            <dsp:SQL>
              itsm.[State] = @StateValue
            </dsp:SQL>
          </dsp:DataSource>
        </dsp:FilterConditions>
      </dsp:Parameter>
		</Parameters>
	</DataSource>

  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMSupplierRequest AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] != @DeletedState
        AND (
          (
            ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter|]#
          )
          OR
          (
            ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMSupplierRequest(itsm)|ITSMSupplierRequestReporter,ITSMAuthor|]#
          )
          OR
          (
            #PERMISSION[ITSMSupplierRequest(itsm)]#
          )
        ) #FILTER# #DYNAMICWHERE#
    ]]></SQL>
    <Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StateValue" ConstantType="LocalVariable" DataType="Number" >
        <dsp:FilterConditions>
          <dsp:DataSource>
            <dsp:SQL>
              itsm.[State] = @StateValue
            </dsp:SQL>
          </dsp:DataSource>
        </dsp:FilterConditions>
      </dsp:Parameter>
    </Parameters>
  </CountDataSource>

  <Sections>
    <Section xsi:type="ExportSection" Ident="BasicExportSection" TitleResourceKey="BasicExportSection_ITSM">
      <DataSource>
        <GeneratorSnippet UseGenerator="Common/XML/CopyXPathContent" SourceXPath="/DataView/DataSource" CopyMode="inner" />
      </DataSource>
    </Section>
  </Sections>

</DataView> 