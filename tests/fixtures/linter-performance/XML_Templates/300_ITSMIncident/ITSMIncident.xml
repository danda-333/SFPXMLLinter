					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="IncidentEvaluationState" DataType="Number" Value="120" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedState" DataType="Number" Value="130" />

					</Parameters>
				</Condition>
