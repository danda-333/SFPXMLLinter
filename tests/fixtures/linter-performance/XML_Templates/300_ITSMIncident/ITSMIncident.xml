		<Section xsi:type="GlobalChangeSection" Ident="SuspendSolutionGlobalChangeSection">
			<ValidationBeforeOpen ErrorMessageResourceKey="SuspendSolutionGlobalChangeSection_Error_ITSM">
				<Condition>
					<SQL>
						
						SELECT 1 AS ID
						WHERE
							(
								SELECT COUNT(itsReq.ID)
								FROM @SelectedIDs AS selIDs
								INNER JOIN usr.ITSMIncident AS itsReq ON itsReq.ID = selIDs.ID
								WHERE itsReq.[State] NOT IN (
									@SolutionAssignedToTeamState
									,@SolutionAssignedState
									,@SolutionInternallySuspendedState
									,@SolutionSuspendedForReviewState
									,@ResolvedForReviewState
								)
							) > 0

					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionAssignedToTeamState" DataType="Number" Value="40" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionAssignedState" DataType="Number" Value="50" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionInternallySuspendedState" DataType="Number" Value="60" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SolutionSuspendedForReviewState" DataType="Number" Value="70" />
						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ResolvedForReviewState" DataType="Number" Value="90" />

					</Parameters>
				</Condition>
			</ValidationBeforeOpen>
			<Controls>
