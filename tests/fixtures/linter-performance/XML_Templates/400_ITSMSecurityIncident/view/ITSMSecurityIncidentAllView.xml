        AND (
          (
            ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMSecurityIncident(itsm)|ITSMSecurityIncidentReporter|]#
          )
          OR
          (
            ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMSecurityIncident(itsm)|ITSMSecurityIncidentReporter,ITSMAuthor|]#
          )
          OR
          (
            #PERMISSION[ITSMSecurityIncident(itsm)]#
          )
        ) #FILTER#
    ]]></SQL>
    <Parameters>
