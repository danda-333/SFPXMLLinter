		<Section xsi:type="GlobalChangeSection" Ident="ParentITSMGlobalChangeSection">
			<ValidationBeforeOpen ErrorMessageResourceKey="ParentITSMGlobalChangeSection_Error_ITSM">
				<Condition>
					<SQL>
						
						SELECT 1 AS ID
						WHERE
							(
								SELECT COUNT(itsReq.ID)
								FROM @SelectedIDs AS selIDs
								INNER JOIN usr.ITSMChange AS itsReq ON itsReq.ID = selIDs.ID
								WHERE itsReq.[State] IN (
									@ClosedState
								)
							) > 0

					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="220" />
					</Parameters>
				</Condition>
			</ValidationBeforeOpen>
