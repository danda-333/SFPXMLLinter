		</ControlShareCode> <!-- <FormControl xsi:type="ShareCodeControl" Ident="EnableAcceptanceControlShare" /> -->
		
		<ControlShareCode Ident="ShowAcceptanceControlShare">
			<Controls>
				<FormControl Ident="ApprovalSubmissionDate" IsVisible="true" />
				<FormControl Ident="ApprovalSubmissionInformation" IsVisible="true" />
				<FormControl Ident="ApprovalConclusion" IsVisible="true" />
        <FormControl xsi:type="IFControl">
          <Condition>
            <SQL><![CDATA[
              SELECT IIF(
                EXISTS(
                  SELECT NULL
                  FROM dbo.History
                  WHERE
                    TableID = @ID
                    AND FormIdent = @FormIdent
                    AND HistoryTypeID = @ChangeState
                    AND [State] = @AcceptanceState
                )
                ,1
                ,0
              )
            ]]></SQL>
            <Parameters>
              <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ShowSubcategory" DataType="Bool" />
              <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ChangeState" DataType="String" Value="ChangeState" />
              <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="AcceptanceState" DataType="Number" Value="170" />
              <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" Value="ITSMChange" />
              <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ID" DataType="String" />
            </Parameters>
          </Condition>
          <TrueControls>
            <FormControl Ident="PHAcceptance" IsVisible="true"/>
          </TrueControls>
        </FormControl>
			</Controls>
		</ControlShareCode> <!-- <FormControl xsi:type="ShareCodeControl" Ident="ShowAcceptanceControlShare" /> -->
