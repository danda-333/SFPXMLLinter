<?xml version="1.0" encoding="utf-8"?>
<WorkFlow xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" Ident="ITSMChangeWorkFlow" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" FormIdent="ITSMChange" PackageIdent="ITSMPackage">
  <Usings>
		<Using Component="Common/Shared/Assign" FormIdent="ITSMChange" />
		<Using Component="Common/Shared/Assessment" FormIdent="ITSMChange" ITSMType="Change" ApprovedState="80" RejectedState="70"/>
		<Using Component="Common/Shared/FolderGroupSegment" FormIdent="ITSMChange" />
		<Using Component="Common/Shared/ITSMKey" FormIdent="ITSMChange" KeyPrefix="CH"/>
		<Using Component="Common/Shared/Resolve" FormIdent="ITSMChange" />

		<Using Component="Common/Controls/MainInfoHTMLContentView" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/AdditionalFields" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/ReporterControls" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/CommunicationControls" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/LinkControls" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/TimeLineControls" FormIdent="ITSMChange" />
	</Usings>
  <Definition>
    <States>
      <State Value="0" TitleResourceKey="Deleted_ITSM" ColorCssClass="danger"/>
      <State Value="1" TitleResourceKey="New_ITSM" ColorCssClass="warning"/>

      <!--První stavy-->
      <State Value="10" TitleResourceKey="Open_ITSM" ColorCssClass="warning"/>
      <State Value="20" TitleResourceKey="SentToCoordinator_ITSM" ColorCssClass="primary"/>

      <!--Drobná změna-->
      <State Value="30" TitleResourceKey="HandedToSupplier_ITSM" ColorCssClass="primary"/>
      <State Value="40" TitleResourceKey="PricingOffer_ITSM" ColorCssClass="primary"/>
      <State Value="50" TitleResourceKey="OfferAssessment_ITSM" ColorCssClass="warning"/>
      <State Value="60" TitleResourceKey="AssessmentProcess_ITSM" ColorCssClass="primary"/>
      <State Value="70" TitleResourceKey="OfferRejected_ITSM" ColorCssClass="danger"/>
      <State Value="80" TitleResourceKey="ToRealization_ITSM" ColorCssClass="primary"/>
      <State Value="90" TitleResourceKey="Realization_ITSM" ColorCssClass="warning"/>
      <State Value="100" TitleResourceKey="Solved_ITSM" ColorCssClass="success"/>

      <!--Normální změna-->
      <State Value="110" TitleResourceKey="ChangeCheck_ITSM" ColorCssClass="warning"/>
      <State Value="120" TitleResourceKey="PricingOffer_ITSM" ColorCssClass="warning"/>
      <State Value="130" TitleResourceKey="MaterialOfferProcessed_ITSM" ColorCssClass="primary"/>
      <State Value="140" TitleResourceKey="SentToSign_ITSM" ColorCssClass="warning"/>
      <State Value="150" TitleResourceKey="Approved_ITSM" ColorCssClass="primary"/>
      <State Value="160" TitleResourceKey="Realization_ITSM" ColorCssClass="warning"/>
      <State Value="170" TitleResourceKey="SentToAcceptance_ITSM" ColorCssClass="primary"/>
      <State Value="180" TitleResourceKey="NewExtendDeliveryDateChange_ITSM" ColorCssClass="warning"/>

      <!--Urgentní změna-->
      <State Value="190" TitleResourceKey="DraftSolutionPreparation_ITSM" ColorCssClass="primary"/>
      <State Value="200" TitleResourceKey="Realization_ITSM" ColorCssClass="warning"/>
      <State Value="210" TitleResourceKey="Solved_ITSM" ColorCssClass="success"/>

      <!--Uzavřeno-->
      <State Value="220" TitleResourceKey="Closed_ITSM" ColorCssClass="success"/>
    </States>
  </Definition>

