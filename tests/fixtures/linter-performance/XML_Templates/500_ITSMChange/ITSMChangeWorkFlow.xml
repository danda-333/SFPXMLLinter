  <Steps>
    <Step State="1">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="SendButtonShare" />
          </Buttons>
          <Sections>
            <Section Ident="HeaderSection" IsVisible="false" />
            <Section Ident="TimeLineSection" IsVisible="false" />
          </Sections>
          <Controls>
            <FormControl xsi:type="ShareCodeControl" Ident="EnableBasicControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCategoryControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableLinkControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="ShowReporterContanctInfoDiffControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableReporterInformationControlShare" />
          </Controls>
        </Group>
      </Groups>
    </Step>
    
    <!--První stavy-->
    <Step State="10">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="AssignCoordinatorButtonShare" />
          </Buttons>
          <Controls>
            <FormControl xsi:type="ShareCodeControl" Ident="EnableBasicControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCategoryControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableLinkControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="ShowReporterContanctInfoDiffControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableReporterInformationControlShare" />
          </Controls>
        </Group>
      </Groups>
    </Step>
    <Step State="20">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="SentToProcessButtonShare" />
          </Buttons>
          <Controls>
            <FormControl xsi:type="ShareCodeControl" Ident="EnableBasicControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCategoryControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableLinkControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="ShowReporterContanctInfoDiffControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableReporterInformationControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCommunicationControlShare" />
          </Controls>
        </Group>
      </Groups>
    </Step>

    <!--Drobná změn-->
    <Step State="30">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="SendToPricingOfferButtonShare" />
          </Buttons>
          <Controls>
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCommunicationControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="ShowReporterInformationControlShare" />
            <FormControl xsi:type="ShareCodeControl" Ident="EnableOfferPricingControlShare" />
          </Controls>
        </Group>
      </Groups>
    </Step>
    <Step State="40">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="SendOfferButtonShare" />
          </Buttons>
          <Controls>
						<FormControl xsi:type="ShareCodeControl" Ident="EnableCommunicationControlShare" />
						<FormControl xsi:type="ShareCodeControl" Ident="ShowReporterInformationControlShare" />
            <FormControl xsi:type="ShareCodeControl" Ident="ShowOfferPricingControlShare" />
          </Controls>
        </Group>
      </Groups>
    </Step>
    <Step State="50">
      <Groups>
        <Group>
          <Permissions>
            <string>ITSMChange</string>
          </Permissions>
          <Buttons>
            <Button xsi:type="ShareCodeButton" Ident="SendToAssessmentButtonShare" />
            <Button xsi:type="ShareCodeButton" Ident="ReturnOfferButtonShare" />
          </Buttons>
          <Controls>
