    <ActionShareCode Ident="AssessmentSubFormStateCheckActionShare">
      <Actions>

        <Action xsi:type="IF" ActionStart="AfterSave">
          <Condition>
            <SQL><![CDATA[
              SELECT IIF(
                NOT EXISTS(
									SELECT NULL
									FROM @ITSMAssessmentChangeFakeSubForm
								)
                ,1
                ,0
              )
            ]]></SQL>
            <Parameters>
							<dsp:Parameter xsi:type="dsp:TableParameter" Ident="ITSMAssessmentChangeFakeSubForm"/>
            </Parameters>
          </Condition>
          <TrueActions>
            <Action xsi:type="ChangeState" State="80" ActionStart="AfterSave" />
          </TrueActions>
          <FalseActions>
            <Action xsi:type="ChangeState" State="60" ActionStart="AfterSave" />
          </FalseActions>
        </Action>

      </Actions>
    </ActionShareCode> <!-- <Action xsi:type="ShareCode" Ident="AssessmentSubFormStateCheckActionShare" /> -->

