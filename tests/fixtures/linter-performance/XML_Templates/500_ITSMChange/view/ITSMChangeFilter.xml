<Filter xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" Ident="ITSMChangeFilter" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" PackageIdent="ITSMPackage">
	<Controls>
	
		<Include Component="Common/Shared/FolderGroupSegment" Section="Filter"/>
		<Include Component="Common/Shared/BaseView" Section="Filter" FormIdent="ITSMChange"/>
    
	</Controls>
	<ExtensionControls>
		<Include Component="Common/Controls/ReporterControls" Section="Filter"/>
		<Include Component="Common/Shared/Resolve" Section="Filter"/>
		
		<Control xsi:type="AutoCompleteControl" Ident="CoordinatorAccountID" DataType="Number" TitleResourceKey="CoordinatorAccountID_ITSM">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM">
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						acc.ID
						,acc.FullName
					FROM dbo.Account AS acc
					INNER JOIN dbo.GroupAccount AS gas ON gas.AccountID = acc.ID
					WHERE 
						acc.FullName LIKE @CoordinatorAccountID
						AND acc.[State] = @AccountActiveState
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="CoordinatorAccountID" DataType="String" LikeType="Both" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="AssignedGroupID" DataType="Number" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="AccountActiveState" DataType="Number" Value="1" />
				</Parameters>
			</DataBind>
			<SelectedDataBind>
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						acc.ID
						,acc.FullName
					FROM dbo.Account AS acc
					WHERE 
						acc.ID = @CoordinatorAccountID
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="CoordinatorAccountID" DataType="Number" />
				</Parameters>
			</SelectedDataBind>
      <FilterConditions>
        <DataSource>
          <SQL><![CDATA[
            itsm.[CoordinatorAccountID] = @CoordinatorAccountID
          ]]></SQL>
        </DataSource>
      </FilterConditions>
		</Control>
	</ExtensionControls>

  <FullText>
		<FilterConditions>
			<DataSource>
				<SQL><![CDATA[
					(
						CONTAINS(itsm.*, @FullText)
					)
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="FullText" ConstantType="FullText" DataType="String" />
				</Parameters>
			</DataSource>
		</FilterConditions>
	</FullText>
</Filter>