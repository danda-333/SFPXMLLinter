    <Froms>
      <dsf:From Ident="accCor">
        <dsf:Columns>
          <dsf:string>CoordinatorAccountID</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN dbo.Account as accCor on accCor.ID = itsm.CoordinatorAccountID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="chaManProCat">
        <dsf:Columns>
          <dsf:string>ITSMChangeManagementProcessCategoryGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMChangeManagementProcessCategory as chaManProCat on chaManProCat.Guid = itsm.ITSMChangeManagementProcessCategoryGuid AND chaManProCat.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="opeEnvTyp">
        <dsf:Columns>
          <dsf:string>ITSMOperationalEnvironmentTypeGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMOperationalEnvironmentType as opeEnvTyp on opeEnvTyp.Guid = itsm.ITSMOperationalEnvironmentTypeGuid AND opeEnvTyp.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="chaClaTyp">
        <dsf:Columns>
          <dsf:string>ITSMChangeClassificationTypeGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMChangeClassificationType as chaClaTyp on chaClaTyp.Guid = itsm.ITSMChangeClassificationTypeGuid AND chaClaTyp.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
    </Froms>
		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMChange AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] != @DeletedState
            AND (
              (
                ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter|]#
              )
              OR
              (
                ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter,ITSMAuthor|]#
              )
            ) #FILTER#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" /> 
		</Parameters>
	</DataSource>

  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMChange AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] != @DeletedState
        AND (
          (
            ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter|]#
          )
          OR
          (
            ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMChange(itsm)|ITSMChangeReporter,ITSMAuthor|]#
          )
        ) #FILTER#
    ]]></SQL>
    <Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
    </Parameters>
  </CountDataSource>

  <Sections>
