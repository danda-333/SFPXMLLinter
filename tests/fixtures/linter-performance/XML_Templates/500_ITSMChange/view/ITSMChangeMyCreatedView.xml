        ]]></SQL>
      </Column>
      <Column Ident="ITSMChangeClassificationTypeGuid" TitleResourceKey="ITSMChangeClassificationTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
