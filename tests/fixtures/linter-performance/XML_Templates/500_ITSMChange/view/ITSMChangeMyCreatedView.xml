        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/Resolve" Section="Columns"/>
      <Column Ident="ITSMChangeManagementProcessCategoryGuid" TitleResourceKey="ITSMChangeManagementProcessCategoryGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
