        ]]></SQL>
      </Column>
      <Column Ident="ContractReferenceNumber" TitleResourceKey="ContractReferenceNumber_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[ContractReferenceNumber]
        ]]></SQL>
      </Column>
      <Column Ident="ContractAuthorityNumber" TitleResourceKey="ContractAuthorityNumber_ITSM" TableAlterIdent="tbl" IsOptional="true">
