    <Button xsi:type="LinkButton" Ident="NewITSMChangeButton" FormIdent="ITSMChange" TitleResourceKey="NewITSMChangeButton_ITSM" />
  </Buttons>
  <DataSource FormIdent="ITSMChange">
    <DataPermissions>
      <string>ITSMChangeReporter</string>
    </DataPermissions>
		<Columns>
