<?xml version="1.0" encoding="utf-8"?>
<DataView xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:dws="http://www.gappex.com/sfp/DataView/Settings" xmlns:dsf="http://www.gappex.com/sfp/DataSource/Froms" Ident="ITSMChangeStateCloneView" SegmentType="ITSMChangeSegment" Priority="200" TitleResourceKey="ITSMChangeStateCloneView_ITSMChange" GroupTitleResourceKey="ITSMChangeStateGroup_ITSM" PackageIdent="ITSMPackage" DefaultFilterIdent="ITSMChangeFilter" ShareFilterIdent="ITSMChangeFilter" IsManualPaging="true" IsGeneratePaging="false">
  <XMLDescription><![CDATA[ 
    
    Pohled pro zobrazování všech stavů

  ]]></XMLDescription>
	<Usings>
		<Using Component="Common/Shared/BaseView" FormIdent="ITSMChange"/>
		<Using Component="Common/Shared/FolderGroupSegment" FormIdent="ITSMChange" />
		<Using Component="Common/Controls/ReporterControls" FormIdent="ITSMChange" />
		<Using Component="Common/Shared/Resolve" FormIdent="ITSMChange" />
	</Usings>
	<AccessPermissions>
    <string>ITSMChange</string>
	</AccessPermissions>

  <Settings>
    <dws:Setting xsi:type="dws:CloneDataViewSetting">
      <dws:DataSource>
        <dws:SQL>
          SELECT 
            CONCAT('ITSMChange', REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View')) AS Ident
            ,CONCAT('ITSMChange_',REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View_ITSM')) AS TitleResourceKey
            ,wfState.[Value] AS TypeIdent
            ,200 + wfState.Value AS Priority
            ,wfState.ColorCssClass AS CountColorCssClass
					FROM usr.ITSMGetWorkFlowState('ITSMChangeWorkFlow') AS wfState
					WHERE Value NOT IN (0,1)
					ORDER BY wfState.Value ASC
        </dws:SQL>
        <dws:Parameters>
        </dws:Parameters>
      </dws:DataSource>
    </dws:Setting>
  </Settings>

  <Buttons>
    
	</Buttons>
	<DataSource FormIdent="ITSMChange">
    <DataPermissions>
      <string>ITSMChangeReporter</string>
      <string>ITSMSpecialist</string>
      <string>ITSMOperator</string>
      <string>ITSMSupplier</string>
      <string>ITSMChangeAssignedCoordinator</string>
      <string>ITSMChangeActualAssessment</string>
      <string>ITSMChangeAssessment</string>
    </DataPermissions>
		<Columns>
      <Include Component="Common/Shared/BaseView" Section="Columns"/>
      <Include Component="Common/Shared/ITSMKey" Section="Columns"/>
      <Column Ident="Subject" TitleResourceKey="Subject_ITSM" Width="20" TableAlterIdent="tbl">
        <SQL><![CDATA[
          itsm.[Subject]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/FolderGroupSegment" Section="Columns"/>
      <Include Component="Common/Shared/BaseView" Section="WorkFlowStateColumn" FormIdent="ITSMChange"/>
      <Include Component="Common/Controls/ReporterControls" Section="Columns"/>
      <Column Ident="Description" TitleResourceKey="Description_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[Description]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/Resolve" Section="Columns"/>
      <Column Ident="ITSMChangeManagementProcessCategoryGuid" TitleResourceKey="ITSMChangeManagementProcessCategoryGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          chaManProCat.[TextValue] AS ITSMChangeManagementProcessCategoryGuid
        ]]></SQL>
      </Column>
      <Column Ident="ITSMOperationalEnvironmentTypeGuid" TitleResourceKey="ITSMOperationalEnvironmentTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          opeEnvTyp.[TextValue] AS ITSMOperationalEnvironmentTypeGuid
        ]]></SQL>
      </Column>
      <Column Ident="ITSMChangeClassificationTypeGuid" TitleResourceKey="ITSMChangeClassificationTypeGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
