          itsm.[ContractName]
        ]]></SQL>
      </Column>
      <Column Ident="OrderIssueDate" TitleResourceKey="OrderIssueDate_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[OrderIssueDate]
