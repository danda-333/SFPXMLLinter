		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMChange AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] NOT IN (@DeletedState,@ClosedState)
            AND 
            (
              (itsm.State IN (@Open,@HandedToSupplier,@OfferAssessment,@OfferRejected,@ToRealization,@SmallSolved) AND #PERMISSION[ITSMChange(itsm)|ITSMOperator|]#)
              OR 
              (itsm.State IN (@SentToCoordinator,@ChangeCheck,@MaterialOfferProcessed,@SentToSign,@Approved,@SentToAcceptance,@RealizationExtendDate,@DraftSolutionPreparation,@UrgentRealization,@UrgentSolved) AND #PERMISSION[ITSMChange(itsm)|ITSMChangeAssignedCoordinator|]#)
              OR 
              (itsm.State IN (@SmallChangePricingOffer,@SmallRealization,@NormalChangePricingOffer,@NormalRealization) AND #PERMISSION[ITSMChange(itsm)|ITSMSupplier|]#)
              OR 
              (itsm.State IN (@AssessmentProcess) AND #PERMISSION[ITSMChange(itsm)|ITSMChangeActualAssessment|]#)
            ) #FILTER#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
