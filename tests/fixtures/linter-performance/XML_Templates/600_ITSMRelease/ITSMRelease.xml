		<Control xsi:type="AutoCompleteControl" Ident="ReleaseManagerAccountID" DataType="Number" TitleResourceKey="ReleaseManagerAccountID_ITSM" IsShowRequired="true" IsReadOnly="true">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM">
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						ID,
						FullName
					FROM 
						dbo.Account
					WHERE 
						FullName LIKE @ReleaseManagerAccountID
						AND [State] = @ActiveState
					ORDER BY FullName ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ReleaseManagerAccountID" DataType="String" LikeType="Both" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ActiveState" DataType="Number" Value="1" />

				</Parameters>
			</DataBind>
			<SelectedDataBind>
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="FullName" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						ID, 
						FullName
					FROM 
						dbo.Account
					WHERE 
						ID = @ReleaseManagerAccountID
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ReleaseManagerAccountID" DataType="Number" />
				</Parameters>
			</SelectedDataBind>
			<TimeLineDataBind TransformType="AutoQuery" DatabaseScheme="dbo" FormIdent="Account" KeyColumnIdent="ID" KeyColumnDataType="INT" TitleColumnIdent="FullName" TitleColumnDataType="VARCHAR(MAX)" />
		</Control>
		<Control xsi:type="AutoCompleteControl" Ident="ITSMChangeID" DataType="Number" TitleResourceKey="ReleaseITSMChangeID_ITSM" IsReadOnly="true">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM">
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="Subject" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						ID,
						CONCAT(ITSMKey,' - ',[Subject]) AS [Subject]
					FROM 
						usr.ITSMChange
					WHERE 
						(
							ITSMKey LIKE @ITSMChangeID
							OR
							[Subject] LIKE @ITSMChangeID
						)
						AND [State] != @DeletedState
					ORDER BY CONCAT(ITSMKey,' - ',[Subject]) ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMChangeID" DataType="String" LikeType="Both" />
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />

				</Parameters>
			</DataBind>
			<SelectedDataBind>
				<Columns>
					<Column Ident="ID" DataBindType="Value" />
					<Column Ident="Subject" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						ID,
						CONCAT(ITSMKey,' - ',[Subject]) AS [Subject]
					FROM 
						usr.ITSMChange
					WHERE 
						ID = @ITSMChangeID
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMChangeID" DataType="Number" />
				</Parameters>
			</SelectedDataBind>
			<TimeLineDataBind TransformType="AutoQuery" DatabaseScheme="dbo" FormIdent="Account" KeyColumnIdent="ID" KeyColumnDataType="INT" TitleColumnIdent="FullName" TitleColumnDataType="VARCHAR(MAX)" />
		</Control>
		<Control xsi:type="DropDownListControl" Ident="ITSMReleaseClassificationCategoryGuid" DataType="Guid" TitleResourceKey="ITSMReleaseClassificationCategoryGuid_ITSM" IsReadOnly="true">
			<DataBind DefaultTitleResourceKey="SelectValue_ITSM" DefaultValue="">
				<Columns>
					<Column Ident="Guid" DataBindType="Value" />
					<Column Ident="TextValue" DataBindType="Title" />
				</Columns>
				<SQL><![CDATA[
					SELECT 
						dialsetting.Guid,
						dial.TextValue
					FROM usr.ITSMReleaseClassificationCategory AS dial
					INNER JOIN usr.ITSMReleaseClassificationCategorySetting AS dialsetting 
						ON dialsetting.Guid = dial.Guid
					WHERE 
						dial.LanguageID = @UserLanguageID
						AND dial.[State] != @DeletedState
					ORDER BY dial.OrderValue ASC
				]]></SQL>
				<Parameters>
					<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
					<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number" />
				</Parameters>
			</DataBind>
			<TimeLineDataBind TransformType="SQL" KeyColumnDataType="VARCHAR(MAX)" TitleColumnDataType="VARCHAR(MAX)">
				<SQL><![CDATA[
					SET @Result = (
						SELECT dial.TextValue
						FROM usr.ITSMReleaseClassificationCategory AS dial
							INNER JOIN usr.ITSMReleaseClassificationCategorySetting AS dialsetting 
								ON dialsetting.Guid = dial.Guid
							WHERE 
								dial.LanguageID = @UserLanguageID
								AND dial.[State] != 0
								AND CAST(dialsetting.Guid AS VARCHAR(MAX)) = @Value
					)
				]]></SQL>
			</TimeLineDataBind>
		</Control>
