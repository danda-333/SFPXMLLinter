					SELECT ISNULL(CAST((
						SELECT CONCAT([ITSMKey] , ' ' , LEFT(itsReq.ReleaseName, 20))
						FROM usr.ITSMRelease AS itsReq
						WHERE itsReq.ID = @ID
					) AS NVARCHAR(MAX)), @NewITSMRelease_Title_ITSM) AS Title
