		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMRelease AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] NOT IN (@DeletedState,@ClosedState)
            AND 
            (
              (itsm.State IN (@OpenRelease,@PrepareDeploymentPlan,@RollbackDecision,@Evaluation) AND #PERMISSION[ITSMRelease(itsm)|ITSMReleaseManager|]#)
              OR 
              (itsm.State IN (@ForMyTeamApproval,@ForMyApproval) AND #PERMISSION[ITSMRelease(itsm)|ITSMReleaseActualApprover|]#)
              OR 
              (itsm.State IN (@SecuringShutdown) AND #PERMISSION[ITSMRelease(itsm)|ITSMOperator|]#)
              OR 
              (itsm.State IN (@ReadyForDeployment,@ForTesting,@ForRollbackExecution) AND #PERMISSION[ITSMRelease(itsm)|ITSMSupplier|]#)
            ) #FILTER#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="OpenRelease" DataType="Number" Value="10" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="PrepareDeploymentPlan" DataType="Number" Value="20" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForMyTeamApproval" DataType="Number" Value="30" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForMyApproval" DataType="Number" Value="40" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="SecuringShutdown" DataType="Number" Value="50" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ReadyForDeployment" DataType="Number" Value="60" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForTesting" DataType="Number" Value="70" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="RollbackDecision" DataType="Number" Value="80" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForRollbackExecution" DataType="Number" Value="90" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="Evaluation" DataType="Number" Value="100" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="110" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" /> 
		</Parameters>
