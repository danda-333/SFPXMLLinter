  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMRelease AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] NOT IN (@DeletedState,@ClosedState)
        AND 
        (
          (itsm.State IN (@OpenRelease,@PrepareDeploymentPlan,@RollbackDecision,@Evaluation) AND #PERMISSION[ITSMRelease(itsm)|ITSMReleaseManager|]#)
          OR 
          (itsm.State IN (@ForMyTeamApproval,@ForMyApproval) AND #PERMISSION[ITSMRelease(itsm)|ITSMReleaseActualApprover|]#)
          OR 
          (itsm.State IN (@SecuringShutdown) AND #PERMISSION[ITSMRelease(itsm)|ITSMOperator|]#)
          OR 
          (itsm.State IN (@ReadyForDeployment,@ForTesting,@ForRollbackExecution) AND #PERMISSION[ITSMRelease(itsm)|ITSMSupplier|]#)
        ) #FILTER#
    ]]></SQL>
    <Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="OpenRelease" DataType="Number" Value="10" />
