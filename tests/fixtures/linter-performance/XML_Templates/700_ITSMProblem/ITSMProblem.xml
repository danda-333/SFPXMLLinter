						<Control ID="PHDocumentationCard">
							<div class="row">
								<div class="col-md-12">
									<div class="card">
										<div class="card-header bg-white header-elements-inline">
											<h6 class="card-title">[#Documentation_ITSM#]</h6>
											<div class="header-elements">
												<div class="list-icons">
													<a class="list-icons-item" data-action="collapse" />
												</div>
											</div>
										</div>
										<div class="card-body">
											<div class="row">
												<div class="col-md-12">
													<div class="form-group">
														<ControlLabel ControlID="ITSMGeneralResolutionMethodTypeGuid" />
														<Control ID="ITSMGeneralResolutionMethodTypeGuid" />
													</div>
												</div> 
											</div>
											<div class="row">
												<div class="col-md-12">
													<div class="form-group">
														<ControlLabel ControlID="ProblemCause" />
