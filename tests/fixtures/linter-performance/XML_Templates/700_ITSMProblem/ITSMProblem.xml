												</div> 
											</div>
											<div class="row">
												<div class="col-md-12">
													<div class="form-group">
														<ControlLabel ControlID="SolutionDescription" />
														<Control ID="SolutionDescription" />
													</div>
												</div> 
											</div>
											<div class="row">
												<div class="col-md-12">
													<div class="form-group">
														<ControlLabel ControlID="SolutionAditionalInformation" />
														<Control ID="SolutionAditionalInformation" />
													</div>
												</div> 
											</div>
										</div>
									</div>
								</div>
							</div>
						</Control><!-- Karta Vyřešení -->

					</div><!-- //Pravý sloupec -->

				</div>
				
			]]></HTMLTemplate>
		</Section>
		{{Component:Common/Shared/ITSMKey,Section:Html}}

		<Section xsi:type="GlobalChangeSection" Ident="ParentITSMGlobalChangeSection">
			<ValidationBeforeOpen ErrorMessageResourceKey="ParentITSMGlobalChangeSection_Error_ITSM">
				<Condition>
					<SQL>
						
						SELECT 1 AS ID
						WHERE
							(
								SELECT COUNT(itsReq.ID)
								FROM @SelectedIDs AS selIDs
								INNER JOIN usr.ITSMProblem AS itsReq ON itsReq.ID = selIDs.ID
								WHERE itsReq.[State] IN (
									@ClosedState
								)
							) > 0

					</SQL>
					<Parameters>
						<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="SelectedIDs" ConstantType="SelectedRow" DataType="NumberList"/>

						<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="200" />
					</Parameters>
				</Condition>
			</ValidationBeforeOpen>
			<Buttons>
				<Button xsi:type="FormButton" Ident="SaveButton" />
			</Buttons>
			<Controls>
				<wffc:FormControl Ident="ParentTableID" />
			</Controls>
			<HTMLTemplate>
				<div class="row">
					<div class="col-md-4">
						<div class="form-group">
							<ControlLabel ControlID="ParentTableID" />
							<Control ID="ParentTableID" />
						</div>
					</div>
				</div>
			</HTMLTemplate>
		</Section>

	</Sections>
</Form>