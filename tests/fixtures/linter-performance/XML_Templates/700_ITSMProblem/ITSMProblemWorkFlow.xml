		<ButtonShareCode Ident="AssignToMeButtonShare">
			<Buttons>

				<Button Ident="AssignToMeButton" IsVisible="true">
					<VisibleCondition>
						<SQL><![CDATA[
							DECLARE @PermissionIDs dbo.ListNVarchar100Type;
							INSERT INTO @PermissionIDs VALUES ('ITSMSpecialist'), ('ITSMOperator');

							DECLARE @AllowedGroupNumber INT = 0;

							SELECT @AllowedGroupNumber = COUNT(*)
							FROM usr.ITSM_GetAllowedGroupByFolderTreeAndPermission(
									COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent),
									@PermissionIDs
							) AS itsGagvftap
							INNER JOIN dbo.GroupAccount AS gra ON gra.GroupID = itsGagvftap.GroupID AND gra.AccountID = @UserID

							SELECT IIF(@AllowedGroupNumber = 1, 1, 0)
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</VisibleCondition>
					<Actions>
						<Action xsi:type="SetValue" Ident="Var_ButtonIdent" Value="AssignToMeButton" ActionStart="AfterValidation" />
						<Action xsi:type="ChangeState" State="40" ActionStart="AfterSave" />
						<Action xsi:type="ShareCode" Ident="Assignee_Update_ToMe_ActionShare" />
		        <Action xsi:type="Communication" ControlIdent="Communication" Type="AssignToMeCommunication_ITSM" ActionStart="AfterSave" />
		        <Action xsi:type="Communication" ControlIdent="DialogCommunication" Type="AssignToMeCommunication_ITSM" ActionStart="AfterSave" />
					</Actions>
				</Button>

				<Button Ident="AssignToMeMultipleGroupButton" IsVisible="true">
					<VisibleCondition>
						<SQL><![CDATA[
							DECLARE @PermissionIDs dbo.ListNVarchar100Type;
							INSERT INTO @PermissionIDs VALUES ('ITSMSpecialist'), ('ITSMOperator');

							DECLARE @AllowedGroupNumber INT = 0;

							SELECT @AllowedGroupNumber = COUNT(*)
							FROM usr.ITSM_GetAllowedGroupByFolderTreeAndPermission(
									COALESCE(@ITSMCategoryLevel5Ident, @ITSMCategoryLevel4Ident, @ITSMCategoryLevel3Ident, @ITSMCategoryLevel2Ident, @ITSMCompanyIdent),
									@PermissionIDs
							) AS itsGagvftap
							INNER JOIN dbo.GroupAccount AS gra ON gra.GroupID = itsGagvftap.GroupID AND gra.AccountID = @UserID

							SELECT IIF(@AllowedGroupNumber > 1, 1, 0)
						]]></SQL>
						<Parameters>
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCompanyIdent" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel2Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel3Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel4Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="ITSMCategoryLevel5Ident" DataType="VarChar" MaxLength="900" />
							<dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserID" DataType="Number" ConstantType="UserID" />
						</Parameters>
					</VisibleCondition>
					<Actions>
						<Action xsi:type="SetValue" Ident="Var_ButtonIdent" Value="AssignToMeMultipleGroupButton" ActionStart="AfterValidation" />
						<Action xsi:type="ChangeState" State="40" ActionStart="AfterSave" />
						<Action xsi:type="ShareCode" Ident="Assignee_Update_ToMeMultipleGroup_ActionShare" />
		        <Action xsi:type="Communication" ControlIdent="Communication" Type="AssignToMeMultipleGroupCommunication_ITSM" ActionStart="AfterSave" />
		        <Action xsi:type="Communication" ControlIdent="DialogCommunication" Type="AssignToMeMultipleGroupCommunication_ITSM" ActionStart="AfterSave" />
					</Actions>
				</Button>

			</Buttons>
