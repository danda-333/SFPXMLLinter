<?xml version="1.0" encoding="utf-8"?>
<DataView xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:dws="http://www.gappex.com/sfp/DataView/Settings" xmlns:dsf="http://www.gappex.com/sfp/DataSource/Froms" Ident="ITSMProblemStateCloneView" SegmentType="ITSMProblemSegment" Priority="200" TitleResourceKey="ITSMProblemStateCloneView_ITSMProblem" GroupTitleResourceKey="ITSMProblemStateGroup_ITSM" PackageIdent="ITSMPackage" DefaultFilterIdent="ITSMProblemFilter" ShareFilterIdent="ITSMProblemFilter" IsManualPaging="true" IsGeneratePaging="false">
  <XMLDescription><![CDATA[ 
    
    Pohled pro zobrazování všech stavů

  ]]></XMLDescription>
	<Usings>
		<Using Component="Common/Shared/BaseView" FormIdent="ITSMProblem"/>
		<Using Component="Common/Shared/Assign" FormIdent="ITSMProblem" AssignedToTeamState="30" />
		<Using Component="Common/Shared/FolderGroupSegment" FormIdent="ITSMProblem" />
		<Using Component="Common/Controls/ReporterControls" FormIdent="ITSMProblem" />
		<Using Component="Common/Shared/SuspendSolution"/>
		<Using Component="Common/Shared/SuspendApproval"/>
		<Using Component="Common/Shared/Resolve" FormIdent="ITSMProblem" />
	</Usings>
	<AccessPermissions>
    <string>ITSMProblem</string>
	</AccessPermissions>

  <Settings>
    <dws:Setting xsi:type="dws:CloneDataViewSetting">
      <dws:DataSource>
        <dws:SQL>
          SELECT 
            CONCAT('ITSMProblem', REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View')) AS Ident
            ,CONCAT('ITSMProblem_',REPLACE(wfState.[TitleResourceKey],'_ITSM', 'View_ITSM')) AS TitleResourceKey
            ,wfState.[Value] AS TypeIdent
            ,200 + wfState.Value AS Priority
            ,wfState.ColorCssClass AS CountColorCssClass
					FROM usr.ITSMGetWorkFlowState('ITSMProblemWorkFlow') AS wfState
					WHERE Value NOT IN (0,1)
					ORDER BY wfState.Value ASC
        </dws:SQL>
        <dws:Parameters>
        </dws:Parameters>
      </dws:DataSource>
    </dws:Setting>
  </Settings>

  <Buttons>
    
	</Buttons>
	<DataSource FormIdent="ITSMProblem">
    <DataPermissions>
      <string>ITSMProblemReporter</string>
      <string>ITSMSpecialist</string>
      <string>ITSMOperator</string>
      <string>ITSMSupplier</string>
    </DataPermissions>
		<Columns>
      <Include Component="Common/Shared/BaseView" Section="Columns"/>
      <Include Component="Common/Shared/ITSMKey" Section="Columns"/>
      <Column Ident="Subject" TitleResourceKey="Subject_ITSM" Width="20" TableAlterIdent="tbl">
        <SQL><![CDATA[
          itsm.[Subject]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/FolderGroupSegment" Section="Columns"/>
      <Include Component="Common/Shared/BaseView" Section="WorkFlowStateColumn" FormIdent="ITSMProblem"/>
      <Include Component="Common/Controls/ReporterControls" Section="Columns"/>
      <Column Ident="Description" TitleResourceKey="Description_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[Description]
        ]]></SQL>
      </Column>
      <Column Ident="ProblemCause" TitleResourceKey="ProblemCause_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[ProblemCause]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/Resolve" Section="Columns"/>
      <Include Component="Common/Shared/Assign" Section="Columns"/>
		</Columns>
    <Froms>
    </Froms>
		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMProblem AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] != @DeletedState
            AND (
              (
                ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMProblem(itsm)|ITSMProblemReporter|]#
              )
              OR
              (
                ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMProblem(itsm)|ITSMProblemReporter,ITSMAuthor|]#
              )
              OR
              (
                #PERMISSION[ITSMProblem(itsm)]#
              )
            ) #FILTER# #DYNAMICWHERE#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" /> 
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="TypeIdent" ConstantType="LocalVariable" DataType="String" >
        <dsp:FilterConditions>
          <dsp:DataSource>
            <dsp:SQL>
              (itsm.[State] = @TypeIdent)
            </dsp:SQL>
          </dsp:DataSource>
        </dsp:FilterConditions>
      </dsp:Parameter>
		</Parameters>
	</DataSource>

  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMProblem AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] != @DeletedState
        AND (
          (
            ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMProblem(itsm)|ITSMProblemReporter|]#
          )
          OR
          (
            ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMProblem(itsm)|ITSMProblemReporter,ITSMAuthor|]#
          )
          OR
          (
            #PERMISSION[ITSMProblem(itsm)]#
          )
				) #FILTER# #DYNAMICWHERE#
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="TypeIdent" ConstantType="LocalVariable" DataType="String" >
        <dsp:FilterConditions>
          <dsp:DataSource>
            <dsp:SQL>
              (itsm.[State] = @TypeIdent)
            </dsp:SQL>
          </dsp:DataSource>
        </dsp:FilterConditions>
      </dsp:Parameter>
		</Parameters>
  </CountDataSource>

  <Sections>
    <Section xsi:type="ExportSection" Ident="BasicExportSection" TitleResourceKey="BasicExportSection_ITSM">
      <DataSource>
        <GeneratorSnippet UseGenerator="Common/XML/CopyXPathContent" SourceXPath="/DataView/DataSource" CopyMode="inner" />
      </DataSource>
    </Section>
  </Sections>
</DataView> 