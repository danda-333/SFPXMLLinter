<?xml version="1.0" encoding="utf-8"?>
<DataView xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:dvs="http://www.gappex.com/sfp/DataView/Settings" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" xmlns:dsf="http://www.gappex.com/sfp/DataSource/Froms" Ident="ITSMInovationToMySolutionView" SegmentType="ITSMInovationSegment" TitleResourceKey="ITSMInovationToMySolutionView_ITSM" GroupTitleResourceKey="ITSMInovationGroup_ITSM" Priority="130" IsManualPaging="true" IsGeneratePaging="false" DefaultFilterIdent="ITSMInovationFilter" ShareFilterIdent="ITSMInovationFilter" CountColorCssClass="warning" PackageIdent="ITSMPackage">
	<Usings>
		<Using Component="Common/Shared/BaseView" FormIdent="ITSMInovation"/>
		<Using Component="Common/Shared/FolderGroupSegment" FormIdent="ITSMInovation" />
		<Using Component="Common/Controls/ReporterControls" FormIdent="ITSMInovation" />
	</Usings>
  <AccessPermissions>
    <string>ITSMInovation</string>
  </AccessPermissions>
	<Settings>
		<dvs:Setting xsi:type="dvs:DataTableSetting" IsResponsive="false" IsClassicPaging="true"/>
	</Settings>
  <Buttons>
    <Button xsi:type="LinkButton" Ident="NewITSMInovationButton" FormIdent="ITSMInovation" TitleResourceKey="NewITSMInovationButton_ITSM" />
  </Buttons>
  <DataSource FormIdent="ITSMInovation">
		<Columns>
      <Include Component="Common/Shared/BaseView" Section="Columns"/>
      <Include Component="Common/Shared/ITSMKey" Section="Columns"/>
      <Column Ident="Subject" TitleResourceKey="Subject_ITSM" Width="20" TableAlterIdent="tbl">
        <SQL><![CDATA[
          itsm.[Subject]
        ]]></SQL>
      </Column>
      <Include Component="Common/Shared/FolderGroupSegment" Section="Columns"/>
      <Include Component="Common/Shared/BaseView" Section="WorkFlowStateColumn" FormIdent="ITSMInovation"/>
      <Include Component="Common/Controls/ReporterControls" Section="Columns"/>
      <Column Ident="Description" TitleResourceKey="Description_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.[Description]
        ]]></SQL>
      </Column>
      <Column Ident="RequestedChangeJustification" TitleResourceKey="RequestedChangeJustification_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.RequestedChangeJustification
        ]]></SQL>
      </Column>
      <Column Ident="RequestedChangeRisk" TitleResourceKey="RequestedChangeRisk_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.RequestedChangeRisk
        ]]></SQL>
      </Column>
      <Column Ident="RequestedChangeDescription" TitleResourceKey="RequestedChangeDescription_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.RequestedChangeDescription
        ]]></SQL>
      </Column>
      <Column Ident="DecisionInformation" TitleResourceKey="DecisionInformation_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.DecisionInformation
        ]]></SQL>
      </Column>
      <Column Ident="VOICTDecisionDateTime" TitleResourceKey="VOICTDecisionDateTime_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          itsm.VOICTDecisionDateTime
        ]]></SQL>
      </Column>
      <Column Ident="ITSMImplementationChangeProposalDecisionGuid" TitleResourceKey="ITSMImplementationChangeProposalDecisionGuid_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          impChaProDec.TextValue AS ITSMImplementationChangeProposalDecisionGuid
        ]]></SQL>
      </Column>
      <Column Ident="ITSMChangeID" TitleResourceKey="ITSMChangeID_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          CONCAT(itsmCha.ITSMKey,' - ',itsmCha.[Subject]) AS ITSMChangeID
        ]]></SQL>
      </Column>
      <Column Ident="CoordinatorAccountIDs" TitleResourceKey="CoordinatorAccountIDs_ITSM" TableAlterIdent="tbl" IsOptional="true">
        <SQL><![CDATA[
          STUFF(
            (
              SELECT ', ' + acc.FullName
              FROM dbo.MultiSelect AS mus
              INNER JOIN dbo.Account as acc on acc.ID = mus.[Value]
              WHERE 
                mus.TableID = itsm.ID
                AND mus.FormIdent = @FormIdent
                AND mus.ControlIdent = @ControlIdent

              FOR XML PATH('')
            )
          , 1, 2, '') AS CoordinatorAccountIDs
        ]]></SQL>
      </Column>
		</Columns>
    <Froms>
      <dsf:From Ident="impChaProDec">
        <dsf:Columns>
          <dsf:string>ITSMImplementationChangeProposalDecisionGuid</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMImplementationChangeProposalDecision as impChaProDec on impChaProDec.Guid = itsm.ITSMImplementationChangeProposalDecisionGuid AND impChaProDec.LanguageID = @UserLanguageID
        </dsf:SQL>
      </dsf:From>
      <dsf:From Ident="itsmCha">
        <dsf:Columns>
          <dsf:string>ITSMChangeID</dsf:string>
        </dsf:Columns>
        <dsf:SQL>
          LEFT JOIN usr.ITSMChange as itsmCha on itsmCha.ID = itsm.ITSMChangeID
        </dsf:SQL>
      </dsf:From>
    </Froms>
		<SQL><![CDATA[
      SELECT *
      FROM (
        SELECT *, #ROWNUM#
        FROM (
          SELECT 
            itsm.ID
            #ADDCOLUMN#
          FROM usr.ITSMInovation AS itsm
          INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
          #ADDFROM#
          WHERE
            itsm.[State] NOT IN (@DeletedState,@ClosedState)
            AND 
            (
              (itsm.State IN (@ToOperatorAssessment,@Postponed) AND #PERMISSION[ITSMInovation(itsm)|ITSMOperator|]#)
              OR
              (itsm.State IN (@CompletenessCheck,@ToCoordinator) AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationProjectOffice|]#)
              OR
              (itsm.State = @ForApproval AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationVOICT|]#)
              OR
              (itsm.State = @ForRealization AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationAssignedCoordinator|]#)
              OR
              (
                itsm.State = @ForClosure 
                AND 
                (
                  (
                    ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationReporter|]#
                  )
                  OR
                  (
                    ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationReporter,ITSMAuthor|]#
                  )
                )
              )
            ) #FILTER#
        ) AS tbl
      ) AS tbl
      WHERE RowNum BETWEEN @StartPage AND @EndPage
    ]]></SQL>
		<Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ToOperatorAssessment" DataType="Number" Value="10" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="CompletenessCheck" DataType="Number" Value="20" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForApproval" DataType="Number" Value="30" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ToCoordinator" DataType="Number" Value="40" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForRealization" DataType="Number" Value="50" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForClosure" DataType="Number" Value="70" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="80" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="Postponed" DataType="Number" Value="90" />
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="ITSMInovation" />
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ControlIdent" DataType="String" MaxLength="50" Value="CoordinatorAccountIDs" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="StartPage" ConstantType="StartPage" DataType="Number" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="EndPage" ConstantType="EndPage" DataType="Number" /> 
		</Parameters>
	</DataSource>

  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(itsm.ID)
      FROM usr.ITSMInovation AS itsm
      INNER JOIN usr.ITSM_FolderTreeView AS ftvCom ON ftvCom.FolderTreeIdent = itsm.ITSMCompanyIdent
      WHERE
        itsm.[State] NOT IN (@DeletedState,@ClosedState)
        AND 
        (
          (itsm.State IN (@ToOperatorAssessment,@Postponed) AND #PERMISSION[ITSMInovation(itsm)|ITSMOperator|]#)
          OR
          (itsm.State IN (@CompletenessCheck,@ToCoordinator) AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationProjectOffice|]#)
          OR
          (itsm.State = @ForApproval AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationVOICT|]#)
          OR
          (itsm.State = @ForRealization AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationAssignedCoordinator|]#)
          OR
          (
            itsm.State = @ForClosure 
            AND 
            (
              (
                ftvCom.IsShareAmongAuthors = 0 AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationReporter|]#
              )
              OR
              (
                ftvCom.IsShareAmongAuthors = 1 AND #PERMISSION[ITSMInovation(itsm)|ITSMInovationReporter,ITSMAuthor|]#
              )
            )
          )
        ) #FILTER#
    ]]></SQL>
    <Parameters>
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ToOperatorAssessment" DataType="Number" Value="10" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="CompletenessCheck" DataType="Number" Value="20" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForApproval" DataType="Number" Value="30" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ToCoordinator" DataType="Number" Value="40" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForRealization" DataType="Number" Value="50" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ForClosure" DataType="Number" Value="70" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ClosedState" DataType="Number" Value="80" />
			<dsp:Parameter xsi:type="dsp:ValueParameter" Ident="Postponed" DataType="Number" Value="90" />
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="FormIdent" DataType="String" MaxLength="50" Value="ITSMInovation" />
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="ControlIdent" DataType="String" MaxLength="50" Value="CoordinatorAccountIDs" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" ConstantType="UserLanguageID" DataType="Number"/>
    </Parameters>
  </CountDataSource>

