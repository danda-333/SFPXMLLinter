<?xml version="1.0" encoding="utf-8"?>
<DataView xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:dsp="http://www.gappex.com/sfp/DataSource/Parameters" Ident="ITSMKnowledgeBaseAllView" SegmentType="ITSMKnowledgeBaseSegment" TitleResourceKey="ITSMKnowledgeBaseAllView_ITSM" GroupTitleResourceKey="ITSMKnowledgeBaseGroup_ITSM" Priority="12" DefaultFilterIdent="ITSMKnowledgeBaseFilter" CountColorCssClass="primary" PackageIdent="ITSMPackage"> 
	<XMLDescription><![CDATA[
		
    Číselník: Způsob vyřešení
  	
	]]></XMLDescription>
  <AccessPermissions>
    <string>ITSMSettingAdmin</string>
  </AccessPermissions>

  <Buttons>
    <Button xsi:type="LinkButton" Ident="NewITSMKnowledgeBaseButton" FormIdent="ITSMKnowledgeBaseSetting" TitleResourceKey="NewITSMKnowledgeBaseButton_ITSM" />
  </Buttons>

  <DataSource FormIdent="ITSMKnowledgeBaseSetting">
    <DataPermissions>
      <string>ITSMSettingAdmin</string>
    </DataPermissions>

    <Columns>
      <Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" Width="10" IsVisible="true" DataType="Number" IsDefaultSort="true" SortType="ASC" />
      <Column Ident="Title" TitleResourceKey="Title_ITSM" Width="30" />
      <Column Ident="Guid" TitleResourceKey="Guid_ITSM" Width="15" />
      <Column Ident="LanguageID" TitleResourceKey="LanguageID_ITSM" Width="10" />
      <Column Ident="CreateDate" TitleResourceKey="CreateDate_ITSM" Width="10" DataType="DateTime" />
      <Column Ident="AccountID" TitleResourceKey="AccountID_ITSM" Width="10" />
    </Columns>

    <SQL><![CDATA[
      SELECT dialSetting.ID,
        dial.Title,
        dial.Guid,
        lan.[Name] AS LanguageID,
        dial.CreateDate,
        accCreator.FullName AS AccountID
      FROM usr.ITSMKnowledgeBaseSetting AS dialSetting
      INNER JOIN usr.ITSMKnowledgeBase AS dial
        ON dial.Guid = dialSetting.Guid
        AND dial.LanguageID = @UserLanguageID
      INNER JOIN dbo.Account AS accCreator
        ON accCreator.ID = dialSetting.AccountID
      INNER JOIN dbo.Language AS lan
        ON lan.ID = dial.LanguageID
      WHERE dialSetting.[State] != @DeletedState
      #FILTER#
    ]]></SQL>

    <Parameters>
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" DataType="Number" ConstantType="UserLanguageID" />
    </Parameters>
  </DataSource>

  <CountDataSource>
    <SQL><![CDATA[
      SELECT COUNT(dial.ID)
      FROM usr.ITSMKnowledgeBaseSetting AS dialSetting
      INNER JOIN usr.ITSMKnowledgeBase AS dial
        ON dial.Guid = dialSetting.Guid
        AND dial.LanguageID = @UserLanguageID
      WHERE dialSetting.[State] != @DeletedState
      #FILTER#
    ]]></SQL>

    <Parameters>
      <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
      <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" DataType="Number" ConstantType="UserLanguageID" />
    </Parameters>
  </CountDataSource>

  <Sections>

    <Section xsi:type="ExportSection" Ident="BasicExport" TitleResourceKey="BasicExport_ITSM" IsExportSetting="true">
      <DataSource FormIdent="ITSMKnowledgeBaseSetting">
        <DataPermissions>
          <string>ITSMSettingAdmin</string>
        </DataPermissions>

        <Columns>
          <Column Ident="ID" TitleResourceKey="ID_ITSM" IsPrimaryKey="true" Width="10" IsVisible="true" DataType="Number" />
          <Column Ident="TextValue" TitleResourceKey="TextValue_ITSM" Width="25" />
          <Column Ident="Guid" TitleResourceKey="Guid_ITSM" Width="20" />
          <Column Ident="LanguageID" TitleResourceKey="LanguageID_ITSM" Width="10" />
          <Column Ident="CreateDate" TitleResourceKey="CreateDate_ITSM" Width="10" DataType="DateTime" />
          <Column Ident="AccountID" TitleResourceKey="AccountID_ITSM" Width="15" />
          <Column Ident="FunctionalKey" TitleResourceKey="FunctionalKey_ITSM" Width="10" />
        </Columns>

        <SQL><![CDATA[
          SELECT
            dialSetting.ID,
            dial.TextValue,
            dial.Guid,
            lan.[Name] AS LanguageID,
            dial.CreateDate,
            accCreator.FullName AS AccountID,
            dialSetting.FunctionalKey
          FROM usr.ITSMKnowledgeBaseSetting AS dialSetting
          INNER JOIN usr.ITSMKnowledgeBase AS dial
            ON dial.Guid = dialSetting.Guid
            AND dial.LanguageID = @UserLanguageID
          INNER JOIN dbo.Account AS accCreator
            ON accCreator.ID = dialSetting.AccountID
          INNER JOIN dbo.Language AS lan
            ON lan.ID = dial.LanguageID
          WHERE dialSetting.[State] != @DeletedState
          #FILTER#
        ]]></SQL>

        <Parameters>
          <dsp:Parameter xsi:type="dsp:ValueParameter" Ident="DeletedState" DataType="Number" Value="0" />
          <dsp:Parameter xsi:type="dsp:VariableParameter" Ident="UserLanguageID" DataType="Number" ConstantType="UserLanguageID" />
        </Parameters>
      </DataSource>
    </Section>

  </Sections>

</DataView>